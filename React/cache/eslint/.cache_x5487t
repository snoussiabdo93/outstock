 </h4>\r\n                  <Link href={`/product-details/${prd.id}`}>\r\n                    <a className=\"link-btn\">discover now</a>\r\n                  </Link>\r\n                </div>\r\n              </div>\r\n            ))}\r\n            <div className=\"row\">\r\n              <div className=\"col-xl-6 offset-xl-6 col-lg-6 offset-lg-6\">\r\n                <div className=\"product__slider-2\">\r\n\r\n                  <Slider {...settings}>\r\n                    {\r\n                      trendingItems.map((item, index) => {\r\n                        return <div key={index}>\r\n                          <div className=\"product__item\">\r\n                            {\r\n                              item.product.map((product, index) => (\r\n                                <div key={index} className=\"product__wrapper mb-60\">\r\n                                  <div className=\"product__thumb\">\r\n                                    <Link href={`/product-details/${product.id}`}>\r\n                                      <a className=\"w-img\">\r\n                                        <img src={product.img} alt=\"product-img\" />\r\n                                        {product.thumb_img &&\r\n                                          <img className=\"product__thumb-2\" src={product.thumb_img} alt=\"product-img\" />\r\n                                        }\r\n                                      </a>\r\n                                    </Link>\r\n                                    <div className=\"product__action transition-3\">\r\n                                      <button onClick={() => dispatch(add_to_wishlist(product))}\r\n                                       data-bs-toggle=\"tooltip\" data-bs-placement=\"top\" \r\n                                      title=\"Add to Wishlist\">\r\n                                        <i className=\"fal fa-heart\"></i>\r\n                                      </button>\r\n                                      <Link href={`/product-details/${product.id}`}>\r\n                                        <a data-bs-toggle=\"tooltip\" data-bs-placement=\"top\" title=\"Details\">\r\n                                          <i className=\"fal fa-link\"></i>\r\n                                        </a>\r\n                                      </Link>\r\n                                      {/* <!-- Button trigger modal --> */}\r\n                                      <a onClick={() => dispatch(single_product(product.id))} href=\"#\" data-bs-toggle=\"modal\" data-bs-target=\"#productModalId\">\r\n                                        <i className=\"fal fa-search\"></i>\r\n                                      </a>\r\n                                    </div>\r\n\r\n                                    {product.product__sale && <div className=\"product__sale\">\r\n                                      {product.product__sale.map((item, index) => (\r\n                                        <span key={index} className={`${item === 'new' ? 'new' : 'percent'}`}>\r\n                                          {item}\r\n                                        </span>\r\n                                      ))}\r\n                                    </div>}\r\n\r\n                                  </div>\r\n                                  <div className=\"product__content p-relative\">\r\n                                    <div className=\"product__content-inner\">\r\n                                      <h4>\r\n                                        <Link href={`/product-details/${product.id}`}>\r\n                                          <a>{product.title}</a>\r\n                                        </Link>\r\n                                      </h4>\r\n                                      <div className=\"product__price transition-3\">\r\n                                        <span>${product.price}.00</span>\r\n                                        {product.old_price && <span className=\"old-price\">${product.old_price}.00</span>}\r\n                                      </div>\r\n                                    </div>\r\n                                    <div className=\"add-cart p-absolute transition-3\">\r\n                                      <button onClick={() => dispatch(cart_product(product))}>+ Add to Cart</button>\r\n                                    </div>\r\n                                  </div>\r\n                                </div>\r\n                              ))\r\n                            }\r\n\r\n                          </div>\r\n                        </div>\r\n                      })\r\n                    }\r\n\r\n                  </Slider>\r\n\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n\r\n\r\n      {/* product modal start */}\r\n      <ProductModal />\r\n      {/* product modal end */}\r\n\r\n    </>\r\n  );\r\n};\r\n\r\nexport default ProductItems;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-2\\sale-off-area.jsx",["700","701"],[],"import Link from \"next/link\";\r\nimport { useDispatch, useSelector } from \"react-redux\";\r\nimport Slider from \"react-slick\";\r\n\r\nimport { cart_product } from \"../../redux/features/cart-slice\";\r\nimport { single_product } from \"../../redux/features/product-slice\";\r\nimport { add_to_wishlist } from \"../../redux/features/wishlist-slice\";\r\nimport ProductModal from \"../common/modal/product-modal\";\r\n\r\n\r\n// slider setting\r\nconst settings = {\r\n  autoplay: true,\r\n  autoplaySpeed: 10000,\r\n  arrows: false,\r\n  infinite: true,\r\n  slidesToShow: 6,\r\n  slidesToScroll: 1,\r\n  responsive: [\r\n    {\r\n      breakpoint: 1400,\r\n      settings: {\r\n        slidesToShow: 5,\r\n      }\r\n    },\r\n    {\r\n      breakpoint: 1200,\r\n      settings: {\r\n        slidesToShow: 3,\r\n      }\r\n    },\r\n    {\r\n      breakpoint: 992,\r\n      settings: {\r\n        slidesToShow: 2,\r\n      }\r\n    },\r\n    {\r\n      breakpoint: 576,\r\n      settings: {\r\n        slidesToShow: 1,\r\n      }\r\n    },\r\n  ]\r\n};\r\n\r\nconst SaleOffArea = () => {\r\n\r\n  const saleOffProduct = useSelector(state => state.products.products);\r\n  const dispatch = useDispatch();\r\n  // const saleOffProduct = products.map(item => item.product).slice(0,7);\r\n\r\n  return (\r\n    <>\r\n      <section className=\"sale__area pb-55\">\r\n        <div className=\"container\">\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-12\">\r\n              <div className=\"section__title-wrapper text-center mb-55\">\r\n                <div className=\"section__title mb-10\">\r\n                  <h2>Sale Off</h2>\r\n                </div>\r\n                <div className=\"section__sub-title\">\r\n                  <p>Mirum est notare quam littera gothica quam nunc putamus parum claram!</p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div className=\"container-fluid\">\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-12\">\r\n              <div className=\"sale__area-slider-2\">\r\n\r\n                <Slider {...settings}>\r\n                  {\r\n                    saleOffProduct.slice(0, 7).map((item, index) => {\r\n                      return <div key={index}>\r\n                        <div className=\"sale__item\">\r\n                          {\r\n                            item.product.map((product, index) => (\r\n                              <div key={index} className=\"product__wrapper mb-60\">\r\n                                <div className=\"product__thumb\">\r\n                                  <Link href={`/product-details/${product.id}`}>\r\n                                    <a className=\"w-img\">\r\n                                      <img src={product.img} alt=\"product-img\" />\r\n                                      {product.thumb_img &&\r\n                                        <img className=\"product__thumb-2\" src={product.thumb_img} alt=\"product-img\" />\r\n                                      }\r\n                                    </a>\r\n                                  </Link>\r\n                                  <div className=\"product__action transition-3\">\r\n                                    <button onClick={() => dispatch(add_to_wishlist(product))} data-bs-toggle=\"tooltip\" data-bs-placement=\"top\" title=\"Add to Wishlist\">\r\n                                      <i className=\"fal fa-heart\"></i>\r\n                                    </button>\r\n                                    \r\n                                    <Link href={`/product-details/${product.id}`}>\r\n                                      <a data-bs-toggle=\"tooltip\" data-bs-placement=\"top\" title=\"Details\">\r\n                                        <i className=\"fal fa-link\"></i>\r\n                                      </a>\r\n                                    </Link>\r\n\r\n                                    <a onClick={() => dispatch(single_product(product.id))} href=\"#\" data-bs-toggle=\"modal\" data-bs-target=\"#productModalId\">\r\n                                      <i className=\"fal fa-search\"></i>\r\n                                    </a>\r\n                                  </div>\r\n\r\n                                  {product.product__sale && <div className=\"product__sale\">\r\n                                    {product.product__sale.map((item, index) => (\r\n                                      <span key={index} className={`${item === 'new' ? 'new' : 'percent'}`}>\r\n                                        {item}\r\n                                      </span>\r\n                                    ))}\r\n                                  </div>}\r\n\r\n                                </div>\r\n                                <div className=\"product__content p-relative\">\r\n                                  <div className=\"product__content-inner\">\r\n                                    <h4>\r\n                                      <Link href={`/product-details/${product.id}`}>\r\n                                        <a>{product.title}</a>\r\n                                      </Link>\r\n                                    </h4>\r\n                                    <div className=\"product__price transition-3\">\r\n                                      <span>${product.price}.00</span>\r\n                                      <span className=\"old-price\">${product.old_price}.00</span>\r\n                                    </div>\r\n                                  </div>\r\n                                  <div className=\"add-cart p-absolute transition-3\">\r\n                                    <button onClick={() => dispatch(cart_product(product))}>+ Add to Cart</button>\r\n                                  </div>\r\n                                </div>\r\n                              </div>\r\n                            ))\r\n                          }\r\n\r\n                        </div>\r\n                      </div>\r\n                    })\r\n                  }\r\n\r\n                </Slider>\r\n\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n      {/* product modal start */}\r\n      <ProductModal />\r\n      {/* product modal end */}\r\n\r\n    </>\r\n  );\r\n};\r\n\r\nexport default SaleOffArea;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-3\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-3\\testimonial.jsx",["702"],[],"import { useState } from \"react\";\r\nimport Slider from \"react-slick\";\r\n\r\n\r\n// slick setting nav\r\nconst settings_nav = {\r\n  slidesToShow: 3,\r\n  slidesToScroll: 1,\r\n  dots: false,\r\n  centerMode: true,\r\n  centerPadding: 0,\r\n  focusOnSelect: true,\r\n  arrows: false,\r\n  responsive: [\r\n    {\r\n      breakpoint: 576,\r\n      settings: {\r\n        slidesToShow: 1,\r\n        slidesToScroll: 1\r\n      }\r\n    }\r\n  ]\r\n};\r\n\r\n// slick setting\r\nconst settings = {\r\n  slidesToShow: 1,\r\n  slidesToScroll: 1,\r\n  arrows: false,\r\n  fade: true,\r\n  dots: true,\r\n};\r\n\r\n\r\nconst nav_data = [\r\n  { img: '/assets/img/testimonial/person-1.jpg' },\r\n  { img: '/assets/img/testimonial/person-2.jpg' },\r\n  { img: '/assets/img/testimonial/person-3.jpg' },\r\n  { img: '/assets/img/testimonial/person-4.jpg' },\r\n]\r\n\r\nconst testimonial_data = [\r\n  {\r\n    id: 1,\r\n    name: 'Mason Robinson',\r\n    title: 'UX - Designer',\r\n    desc: 'Typi non habent claritatem insitam, est usus legentis in iis qui facit eorum claritatem. Investigationes demonstraverunt lectores legere me lius quod ii legunt saepius consuetudium lectorum.'\r\n  },\r\n  {\r\n    id: 2,\r\n    name: 'David Cruso',\r\n    title: 'Web Developer',\r\n    desc: 'Typi non habent claritatem insitam, est usus legentis in iis qui facit eorum claritatem. Investigationes demonstraverunt lectores legere me lius quod ii legunt saepius consuetudium lectorum.'\r\n  },\r\n  {\r\n    id: 3,\r\n    name: 'Shahnewaz Sakil',\r\n    title: 'Web Designer',\r\n    desc: 'Typi non habent claritatem insitam, est usus legentis in iis qui facit eorum claritatem. Investigationes demonstraverunt lectores legere me lius quod ii legunt saepius consuetudium lectorum.'\r\n  },\r\n  {\r\n    id: 4,\r\n    name: 'Salim Rana',\r\n    title: 'WP Expert',\r\n    desc: 'Typi non habent claritatem insitam, est usus legentis in iis qui facit eorum claritatem. Investigationes demonstraverunt lectores legere me lius quod ii legunt saepius consuetudium lectorum.'\r\n  },\r\n]\r\nconst Testimonial = () => {\r\n\r\n  const [slider1, setSlider1] = useState(null);\r\n  const [slider2, setSlider2] = useState(null);\r\n\r\n  return (\r\n    <>\r\n      <section className=\"testimonial__area box-m-15 pt-100 pb-140\"\r\n        style={{ background: 'url(/assets/img/testimonial/testimonial-bg.jpg)', backgroundRepeat: 'no-repeat', backgroundSize: 'cover', backgroundPosition: 'center' }}>\r\n        <div className=\"container\">\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-8 offset-xl-2 col-lg-8 offset-lg-2\">\r\n              <div className=\"\">\r\n                <Slider asNavFor={slider2} ref={(slider) => setSlider1(slider)} className=\"testimonial__nav\" {...settings_nav}>\r\n                  {nav_data.map((item, index) => (\r\n                    <div key={index} className={`testimonial__nav-thumb item-${index + 1}`}>\r\n                      <img src={item.img} alt=\"person\" />\r\n                    </div>\r\n                  ))}\r\n                </Slider>\r\n\r\n              </div>\r\n              <div className=\" mt-40\">\r\n                <Slider asNavFor={slider1} ref={(slider) => setSlider2(slider)}\r\n                  className=\"testimonial__wrapper\" {...settings}>\r\n                  {testimonial_data.map((item) => (\r\n                    <div key={item.id} className={`testimonial__item item-${item.id}`}>\r\n                      <div className=\"avater__info mb-15\">\r\n                        <h6>{item.name}</h6>\r\n                        <span>{item.title}</span>\r\n                      </div>\r\n                      <p>{item.desc}</p>\r\n                    </div>\r\n                  ))}\r\n                </Slider>\r\n\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default Testimonial;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-4\\hero-slider.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-4\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-5\\hero-slider.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-5\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-6\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-7\\blogs.jsx",["703"],[],"import Link from \"next/link\";\r\nimport Slider from \"react-slick\";\r\n\r\nimport { blogs } from \"../../data\";\r\nimport { SampleNextArrow, SamplePrevArrow } from \"../../utils/slider-arrow\";\r\n\r\nconst blog_items = blogs.filter(blog => blog.blog_two);\r\n\r\n// slider setting\r\nconst settings = {\r\n  autoplay: true,\r\n  autoplaySpeed: 10000,\r\n  infinite: true,\r\n  slidesToShow: 2,\r\n  slidesToScroll: 1,\r\n  nextArrow: <SampleNextArrow />,\r\n  prevArrow: <SamplePrevArrow />,\r\n  responsive: [\r\n    {\r\n      breakpoint: 992,\r\n      settings: {\r\n        slidesToShow: 1,\r\n      }\r\n    },\r\n  ]\r\n};\r\n\r\n\r\nconst Blogs = () => {\r\n  return (\r\n    <>\r\n      <div className=\"blog__slider-area pt-100 pb-100\">\r\n        <div className=\"container custom-container-2\">\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-12\">\r\n              <div className=\"row\">\r\n                <div className=\"col-xl-12\">\r\n                  <div className=\"section__wrapper text-center\">\r\n                    <h3 className=\"section__title-2\"><span> From Our Blog </span></h3>\r\n                    <p>Update The Latest Fashion Trends in The World</p>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div className=\"row mt-40\">\r\n            <div className=\"col-xl-12\">\r\n              <div className=\"blog__slider-active slick-gap slick-carousel\">\r\n\r\n                <Slider {...settings}>\r\n                  {blog_items.map(blog => (\r\n                    <div key={blog.id} className=\"blog__slider-item\">\r\n                      <div className=\"blog-thumb m-img\">\r\n                        <img src={blog.img} alt=\"blog-img\" />\r\n                        <Link href={`/blog-details/${blog.id}`}>\r\n                          <a className=\"btn\">\r\n                            <i className=\"fa fa-link\"></i>\r\n                          </a>\r\n                        </Link>\r\n                      </div>\r\n                      <div className=\"blog__post-content\">\r\n                        <div className=\"blog__wrapper\">\r\n                          <h5 className=\"blog__post-title\">\r\n                            <Link href={`/blog-details/${blog.id}`}>\r\n                              <a>{blog.title}</a>\r\n                            </Link>\r\n                          </h5>\r\n                          <div className=\"article-meta d-flex justify-content-center\">\r\n                            <span className=\"article-author\"><span>By</span> {blog.author}</span>\r\n                            <span> /</span>\r\n                            <span className=\"article-publish\">\r\n                              <i className=\"fa fa-calendar-o\"></i>{blog.date}\r\n                            </span>\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  ))}\r\n                </Slider>\r\n\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default Blogs;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-7\\fashion-prd.jsx",["704","705","706"],[],"import Link from 'next/link';\r\nimport React from 'react';\r\nimport { useDispatch, useSelector } from 'react-redux';\r\n\r\nimport { selectProducts, single_product } from '../../redux/features/product-slice';\r\nimport ProductModal from '../common/modal/product-modal';\r\n\r\nconst FashionProduct = () => {\r\n  const products = useSelector(selectProducts);\r\n  const fashion_products = products.map(item => item.product).flat().filter(item => item.f_prd);\r\n  return (\r\n    <>\r\n      <div className=\"product__view-area pt-60 pb-60\">\r\n        <div className=\"container custom-container-2\">\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-12\">\r\n              <div className=\"section__wrapper text-center\">\r\n                <h3 className=\"section__title-2\"><span>BESTSELLER PRODUCTS</span></h3>\r\n                <p>Eodem modo typi, qui nunc nobis videntur parum clari</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div className=\"row mt-40\">\r\n            <div className=\"col-xl-6 col-lg-6\">\r\n              <div className=\"row\">\r\n                <div className=\"col-lg-12\">\r\n                  <div className=\"row\">\r\n                    {fashion_products.slice(0, 2).map(prd => (\r\n                      <SingleFashionPrd key={prd.id} prd={prd} />\r\n                    ))}\r\n\r\n                  </div>\r\n                </div>\r\n                <div className=\"col-lg-12\">\r\n                  <FashionBigProduct prdNumber={0} />\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"col-lg-6 col-lg-6\">\r\n              <div className=\"row\">\r\n                <div className=\"col-lg-12\">\r\n                  <FashionBigProduct prdNumber={1} />\r\n                </div>\r\n                <div className=\"col-lg-12\">\r\n                  <div className=\"row\">\r\n                    {fashion_products.slice(2, 4).map(prd => (\r\n                      <SingleFashionPrd key={prd.id} prd={prd} />\r\n                    ))}\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default FashionProduct;\r\n\r\n\r\nconst SingleFashionPrd = ({ prd }) => {\r\n  const dispatch = useDispatch();\r\n  return (\r\n    <>\r\n      <div className=\"col-xl-6 col-lg-12 col-md-6\">\r\n        <div className=\"product__item mb-40\">\r\n          <div className=\"product__wrapper\">\r\n            <div className=\"product__thumb\">\r\n              <Link href={`/product-details/${prd.id}`}>\r\n                <a className=\"w-img\">\r\n                  <img src={prd.img} alt=\"product-img\" />\r\n                  <img className=\"product__thumb-2\" src={prd.thumb_img} alt=\"product-img\" />\r\n                </a>\r\n              </Link>\r\n              <div className=\"product__action-3 transition-3\">\r\n                <Link href={`/product-details/${prd.id}`}>\r\n                  <a className=\"action-btn\">\r\n                    <i className=\"fal fa-plus\"></i> Select Option</a>\r\n                </Link>\r\n\r\n                <a className=\"action-btn\" onClick={() => dispatch(single_product(prd.id))} \r\n                href=\"#\" data-bs-toggle=\"modal\" data-bs-target=\"#productModalId\">\r\n                  <i className=\"fal fa-eye\"></i>\r\n                </a>\r\n\r\n              </div>\r\n              {prd.new && <div className=\"product__sale product__sale-3\">\r\n                <span className=\"new\">new</span>\r\n              </div>}\r\n            </div>\r\n            <div className=\"product__content product__content-2 p-relative text-center\">\r\n              <div className=\"product__content-inner\">\r\n                <div className=\"rating\">\r\n                  <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                  <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                  <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                  <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                  <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                </div>\r\n                <h4>\r\n                  <Link href={`/product-details/${prd.id}`}>\r\n                    <a>{prd.title}</a>\r\n                  </Link>\r\n                </h4>\r\n                <div className=\"product__price-3\">\r\n                  <span>${prd.price}.00</span>\r\n                  {prd.old_price && <span className=\"old-price\">\r\n                    <del> ${prd.old_price}.00</del>\r\n                  </span>}\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      {/* product modal start */}\r\n      <ProductModal />\r\n      {/* product modal end */}\r\n\r\n    </>\r\n  )\r\n}\r\n\r\n\r\nconst FashionBigProduct = ({ prdNumber }) => {\r\n  const products = useSelector(state => state.products.products);\r\n  const fashion_big_prd = products.map(item => item.product).flat().filter(item => item.f_prd_big);\r\n  return (\r\n    <div className=\"product__big-image effectThree mb-40\">\r\n      <Link href={`/product-details/${fashion_big_prd[prdNumber].id}`}>\r\n        <a>\r\n          <img src={fashion_big_prd[prdNumber].img} alt=\"\" />\r\n        </a>\r\n      </Link>\r\n    </div>\r\n  )\r\n}","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-7\\feature-products.jsx",["707","708"],[],"import Link from 'next/link';\r\nimport { useDispatch, useSelector } from 'react-redux';\r\nimport Slider from 'react-slick';\r\n\r\nimport { single_product } from '../../redux/features/product-slice';\r\nimport { SampleNextArrow, SamplePrevArrow } from '../../utils/slider-arrow';\r\n\r\n// slick setting\r\nconst settings = {\r\n  autoplay: false,\r\n  autoplaySpeed: 10000,\r\n  slidesToShow: 4,\r\n  nextArrow: <SampleNextArrow />,\r\n  prevArrow: <SamplePrevArrow />,\r\n  responsive: [\r\n    {\r\n      breakpoint: 992,\r\n      settings: {\r\n        slidesToShow: 3,\r\n      }\r\n    },\r\n    {\r\n      breakpoint: 767,\r\n      settings: {\r\n        slidesToShow: 2,\r\n      }\r\n    },\r\n    {\r\n      breakpoint: 576,\r\n      settings: {\r\n        slidesToShow: 1,\r\n      }\r\n    },\r\n  ]\r\n};\r\n\r\n\r\nconst FeatureProducts = () => {\r\n  const products = useSelector(state => state.products.products);\r\n  const fashion_products = products.map(item => item.product).flat().filter(item => item.feature_prd);\r\n  const dispatch = useDispatch();\r\n  return (\r\n    <>\r\n      <div className=\"product__slider-area pt-95 pb-60\">\r\n        <div className=\"container custom-container-2\">\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-12\">\r\n              <div className=\"section__wrapper text-center\">\r\n                <h3 className=\"section__title-2\"><span>FEATURED PRODUCTS</span></h3>\r\n                <p>Claritas est etiam processus dynamicus, qui sequitur.</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div className=\"row mt-40\">\r\n            <div className=\"col-lg-12\">\r\n\r\n              <Slider className='product__slider-active slick-gap slick-carousel' {...settings}>\r\n                {\r\n                  fashion_products.map((prd, index) => {\r\n                    return <div key={index} className=\"product__slider-item\">\r\n                      <div className=\"product__item mb-40\">\r\n                        <div className=\"product__wrapper\">\r\n                          <div className=\"product__thumb\">\r\n                            <Link href={`/product-details/${prd.id}`}>\r\n                              <a className=\"w-img\">\r\n                                <img src={prd.img} alt=\"product-img\" />\r\n                                <img className=\"product__thumb-2\" src={prd.thumb_img} alt=\"product-img\" />\r\n                              </a>\r\n                            </Link>\r\n                            <div className=\"product__action-3 transition-3\">\r\n                              <Link href={`/product-details/${prd.id}`}>\r\n                                <a className=\"action-btn\">\r\n                                  <i className=\"fal fa-plus\"></i> Select Option</a>\r\n                              </Link>\r\n\r\n                              <a className=\"action-btn\" onClick={() => dispatch(single_product(prd.id))} href=\"#\"\r\n                                data-bs-toggle=\"modal\" data-bs-target=\"#productModalId\">\r\n                                <i className=\"fal fa-eye\"></i>\r\n                              </a>\r\n\r\n                            </div>\r\n                            {prd.new && <div className=\"product__sale product__sale-3\">\r\n                              <span className=\"new\">new</span>\r\n                            </div>}\r\n                          </div>\r\n                          <div className=\"product__content product__content-2 p-relative text-center\">\r\n                            <div className=\"product__content-inner\">\r\n                              <div className=\"rating\">\r\n                                <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                                <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                                <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                                <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                                <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                              </div>\r\n                              <h4>\r\n                                <Link href={`/product-details/${prd.id}`}>\r\n                                  <a>{prd.title}</a>\r\n                                </Link>\r\n                              </h4>\r\n                              <div className=\"product__price-3\">\r\n                                <span>${prd.price}.00</span>\r\n                                {prd.old_price && <span className=\"old-price\">\r\n                                  <del> ${prd.old_price}.00</del>\r\n                                </span>}\r\n                              </div>\r\n                            </div>\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  })\r\n                }\r\n              </Slider>\r\n\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default FeatureProducts;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-7\\hero-slider.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-7\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-7\\testimonial.jsx",["709"],[],"import Slider from \"react-slick\";\r\n\r\n\r\nconst testimonial_data = [\r\n  {\r\n    id: 1,\r\n    img: 'assets/img/testimonial/testi1.webp',\r\n    desc: 'Great theme, extended super and fast professional support. easy to use, flexible, visual composer and more functional plugins on board. Yes a real good, strong theme with structured coding. Enjoy it! friendly and super good!'\r\n  },\r\n  {\r\n    id: 2,\r\n    img: 'assets/img/testimonial/testi2.webp',\r\n    desc: 'Great theme, extended super and fast professional support. easy to use, flexible, visual composer and more functional plugins on board. Yes a real good, strong theme with structured coding. Enjoy it! friendly and super good!'\r\n  },\r\n  {\r\n    id: 3,\r\n    img: 'assets/img/testimonial/testi3.webp',\r\n    desc: 'Great theme, extended super and fast professional support. easy to use, flexible, visual composer and more functional plugins on board. Yes a real good, strong theme with structured coding. Enjoy it! friendly and super good!'\r\n  },\r\n]\r\n\r\n// slick setting\r\nconst settings = {\r\n  slidesToShow: 1,\r\n  slidesToScroll: 1,\r\n  arrows: false,\r\n  dots: true,\r\n};\r\n\r\nconst Testimonial = () => {\r\n  return (\r\n    <>\r\n      <div className=\"testimonial__area grey-bg pt-95 pb-95\">\r\n        <div className=\"container custom-container-2\">\r\n          <div className=\"row\">\r\n            <div className=\"col-lg-12\">\r\n              <div className=\"row\">\r\n                <div className=\"col-xl-12\">\r\n                  <div className=\"section__wrapper text-center mb-40\">\r\n                    <h3 className=\"section__title-2\">OUR TESTIMONIAL</h3>\r\n                    <p className=\"sub-title\">Commodo sociosqu venenatis cras dolor sagittis integer luctus sem primis eget maecenas sed urna malesuada consectetuer</p>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div className=\"row\">\r\n            <div className=\"col-lg-12\">\r\n              <div className=\"testimonial__slider-active\">\r\n                <Slider {...settings}>\r\n                  {testimonial_data.map((item) => (\r\n                    <div key={item.id} className=\"testimonail__slider-item\">\r\n                      <div className=\"testimonial__image text-center mb-50\">\r\n                        <img src={item.img} alt=\"\" />\r\n                      </div>\r\n                      <div className=\"testimonial__content\">\r\n                        <p>{item.desc}</p>\r\n                      </div>\r\n                    </div>\r\n                  ))}\r\n                </Slider>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default Testimonial;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-7\\video-box.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.t