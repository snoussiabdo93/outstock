hop-right.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\pages\\shop.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\pages\\wishlist.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\pages\\_app.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog\\blog-area.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-2-col\\blog-2-col.jsx",["657"],[],"import Link from \"next/link\";\r\nimport { useEffect, useState } from \"react\";\r\nimport ReactPaginate from \"react-paginate\";\r\nimport { blogs } from \"../../data\";\r\n\r\nconst items = blogs.slice(0, 8);\r\n\r\nconst BlogTwoCol = () => {\r\n  return (\r\n    <>\r\n      <section className=\"blog__area pt-100 pb-100\">\r\n        <div className=\"container\">\r\n          <div className=\"row\">\r\n            <BlogItems itemsPerPage={6} items={items} />\r\n          </div>\r\n        </div>\r\n      </section>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default BlogTwoCol;\r\n\r\n\r\nexport const BlogItems = ({ itemsPerPage, items, colThree }) => {\r\n  const [currentItems, setCurrentItems] = useState(null);\r\n  const [pageCount, setPageCount] = useState(0);\r\n  const [itemOffset, setItemOffset] = useState(0);\r\n\r\n  useEffect(() => {\r\n    const endOffset = itemOffset + itemsPerPage;\r\n    setCurrentItems(items.slice(itemOffset, endOffset));\r\n    setPageCount(Math.ceil(items.length / itemsPerPage));\r\n  }, [itemOffset, itemsPerPage, items]);\r\n\r\n  const handlePageClick = (event) => {\r\n    const newOffset = (event.selected * itemsPerPage) % items.length;\r\n    setItemOffset(newOffset);\r\n  };\r\n\r\n  return (\r\n    <>\r\n\r\n      {currentItems && currentItems.map((item, index) => (\r\n        <div key={index} className={colThree ? 'col-xl-4 col-lg-4 col-md-6' : \"col-xl-6 col-lg-6 col-md-6\"}>\r\n          <div key={index} className=\"blog__item mb-60\">\r\n            <div className=\"blog__thumb fix\">\r\n              <Link href={`/blog-details/${item.id}`}>\r\n                <a className=\"w-img\">\r\n                  <img src={item.img} alt=\"blog\" />\r\n                </a>\r\n              </Link>\r\n            </div>\r\n            <div className=\"blog__content\">\r\n              <h4>\r\n                <Link href={`/blog-details/${item.id}`}>\r\n                  <a>{item.title}</a>\r\n                </Link>\r\n              </h4>\r\n              <div className=\"blog__meta\">\r\n                <span>By <a href=\"#\">{item.author}</a></span>\r\n                <span>/ {item.date}</span>\r\n              </div>\r\n              <p>{item.desc.substring(0, 120)}[...]</p>\r\n              <Link href={`/blog-details/${item.id}`}>\r\n                <a className=\"os-btn\">read more</a>\r\n              </Link>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      ))}\r\n\r\n\r\n      <div className=\"row \">\r\n        <div className=\"col-xl-12\">\r\n          <div className=\"mt-35 shop-pagination-wrapper d-md-flex justify-content-between align-items-center\">\r\n\r\n            <div className=\"basic-pagination\">\r\n              <ReactPaginate\r\n                nextLabel={<><i className=\"fal fa-angle-right\"></i></>}\r\n                onPageChange={handlePageClick}\r\n                pageRangeDisplayed={3}\r\n                marginPagesDisplayed={2}\r\n                pageCount={pageCount}\r\n                previousLabel={<><i className=\"fal fa-angle-left\"></i></>}\r\n                pageClassName=\"page-item\"\r\n                pageLinkClassName=\"page-link\"\r\n                previousClassName=\"page-item\"\r\n                previousLinkClassName=\"page-link\"\r\n                nextClassName=\"page-item\"\r\n                nextLinkClassName=\"page-link\"\r\n                breakLabel=\"...\"\r\n                breakClassName=\"page-item\"\r\n                breakLinkClassName=\"page-link\"\r\n                containerClassName=\"pagination\"\r\n                activeClassName=\"active\"\r\n                renderOnZeroPageCount={null}\r\n              />\r\n            </div>\r\n\r\n            <div className=\"shop__header-left\">\r\n              <div className=\"show-text bottom\">\r\n                <span>Showing 1–{currentItems?.length} of {items?.length} results</span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n    </>\r\n  )\r\n}","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-2-col\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-2-col-mas\\blog-2-col-mas.jsx",["658"],[],"import Link from \"next/link\";\r\nimport Masonry, { ResponsiveMasonry } from \"react-responsive-masonry\";\r\n\r\nimport { blogs } from '../../data';\r\n\r\nconst items = blogs.filter(blog => blog.masonry).reverse();\r\n\r\nconst BlogTwoCalMas = () => {\r\n  return (\r\n    <>\r\n      <section className=\"blog__area pt-100 pb-100\">\r\n        <div className=\"container\">\r\n          <div className=\"row\">\r\n            <ResponsiveMasonry columnsCountBreakPoints={{ 0: 1, 750: 2, }} >\r\n              <Masonry gutter=\"25px\">\r\n                {items.map((item, index) => (\r\n                  <div key={index} className=\"\">\r\n                    <div className=\"blog__item mb-60\">\r\n                      <div className=\"blog__thumb fix\">\r\n                        <Link href={`/blog-details/${item.id}`}>\r\n                          <a className=\"w-img\">\r\n                            <img src={item.img} alt=\"blog\" />\r\n                          </a>\r\n                        </Link>\r\n                      </div>\r\n                      <div className=\"blog__content\">\r\n                        <h4>\r\n                          <Link href={`/blog-details/${item.id}`}>\r\n                            <a>{item.title}</a>\r\n                          </Link>\r\n                        </h4>\r\n                        <div className=\"blog__meta\">\r\n                          <span>By <a href=\"#\">{item.author}</a></span>\r\n                          <span>/ {item.date}</span>\r\n                        </div>\r\n                        <p>{item.desc}</p>\r\n                        <Link href={`/blog-details/${item.id}`}>\r\n                          <a className=\"os-btn\">read more</a>\r\n                        </Link>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                ))}\r\n              </Masonry>\r\n            </ResponsiveMasonry>\r\n          </div>\r\n\r\n        </div>\r\n      </section>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default BlogTwoCalMas;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-2-col-mas\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-3-col\\blog-three-col.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-3-col\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-details\\blog-details-area.jsx",["659","660","661","662"],[],"import BlogSidebar from '../common/blog/blog-sidebar';\r\nimport { blogs } from '../../data';\r\nimport BlogForm from '../common/form/blog-form';\r\nimport Link from 'next/link';\r\n\r\nconst reviews = [\r\n  {\r\n    img: '/assets/img/blog/comments/avater-1.png',\r\n    name: 'Siarhei Dzenisenka',\r\n    time: '3 Months Ago',\r\n    rating: 4,\r\n  },\r\n  {\r\n    img: '/assets/img/blog/comments/avater-2.png',\r\n    name: 'Julias Roy',\r\n    time: '6 Months Ago',\r\n    rating: 4,\r\n    children: true,\r\n  },\r\n  {\r\n    img: '/assets/img/blog/comments/avater-3.png',\r\n    name: 'Arista Williamson',\r\n    time: '6 Months Ago',\r\n    rating: 4,\r\n  },\r\n]\r\n\r\nconst BlogDetailsArea = ({ item }) => {\r\n  return (\r\n    <>\r\n      <section className=\"blog__area pt-55\">\r\n        <div className=\"container\">\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-9 col-lg-8\">\r\n              <div className=\"postbox__title mb-55\">\r\n                <h1>\r\n                  <Link href={'/blog'}>\r\n                    <a>{item.title}</a>\r\n                  </Link>\r\n                </h1>\r\n                <div className=\"blog__meta\">\r\n                  <span>By <a href=\"#\">{item.author}</a></span>\r\n                  <span>/ {item.date}</span>\r\n                </div>\r\n              </div>\r\n              <div className=\"postbox__thumb w-img\">\r\n                <img src={item.img} alt=\"\" />\r\n              </div>\r\n              <div className=\"postbox__wrapper mb-70\">\r\n                <div className=\"postbox__text mt-65\">\r\n                  <p>Diga, Koma and Torus are three kitchen utensils designed for <span className=\"highlight theme\">Ommo</span>, a new design-oriented brand introduced at the Ambiente show in February 2016. <span className=\"highlight\">Minimalist approach, bright colors, stainless steel and matte plastic</span>, abstract shapes and curved lines are the defining features of these products designed to be extremely functional, user-friendly and fun.</p>\r\n                </div>\r\n                <div className=\"postbox__text\">\r\n                  <p>Diga is a two-color melamine salad bowl where vegetables can be washed, drained and served. The disk at the bottom of the bowl can be turned counterclockwise to drain water when washing vegetables and it can be turned clockwise to lock the drain and hold condiments in the bowl when serving.</p>\r\n                </div>\r\n                <article className=\"postbox format-quote mt-45 mb-50\">\r\n                  <div className=\"postbox__quote\">\r\n                    <blockquote>\r\n                      <p> <i className=\"fas fa-quote-right\"></i> Many desktop publishing packages and web page editors now use Lorem Ipsum as their default model text, and a search for lorem ipsum will uncover many web sites still in their infancy. </p>\r\n                    </blockquote>\r\n                  </div>\r\n                </article>\r\n                <div className=\"postbox__details-img w-img mb-60\">\r\n                  <img src=\"/assets/img/blog/blog-details-sm.jpg\" alt=\"\" />\r\n                </div>\r\n                <div className=\"postbox__text\">\r\n                  <p>Koma and Torus are two tea infusers, each with an original design and a concealed function. Koma has a round base and a long stainless steel-trimmed handle which offers a comfortable grip and allows.\r\n                  </p>\r\n                </div>\r\n                <div className=\"postbox__text\">\r\n                  <p>And the brushed steel cover opens and closes at the touch of a finger to easily fill and empty the infuser. The perfect way to enjoy brewing tea. Torus is donut-shaped and can      cling to any cup. It is accompanied by a case that can contain up to three different diffusers and can be used for dry storage of loose tea.\r\n                  </p>\r\n                </div>\r\n              </div>\r\n              <div className=\"postbox__share mb-95\">\r\n                <div className=\"row\">\r\n                  <div className=\"col-xl-6 col-lg-6 col-md-6\">\r\n                    <div className=\"postbox__social\">\r\n                      <span>Share to friends:</span>\r\n                      <ul>\r\n                        <li><a href=\"#\"><i className=\"fab fa-facebook-f\"></i></a></li>\r\n                        <li><a href=\"#\"><i className=\"fab fa-twitter\"></i></a></li>\r\n                        <li><a href=\"#\"><i className=\"fab fa-dribbble\"></i></a></li>\r\n                        <li><a href=\"#\"><i className=\"fas fa-share-alt\"></i></a></li>\r\n                      </ul>\r\n                    </div>\r\n                  </div>\r\n                  <div className=\"col-xl-6 col-lg-6 col-md-6\">\r\n                    <div className=\"postbox__tag f-right\">\r\n                      <span>Tags :</span>\r\n                      <a href=\"#\">Furniture,</a>\r\n                      <a href=\"#\">Erentheme,</a>\r\n                      <a href=\"#\">Chair, </a>\r\n                      <a href=\"#\">Decor</a>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n              <div className=\"postbox__related-title\">\r\n                <h3>You Might Also Like</h3>\r\n              </div>\r\n              <div className=\"postbox__related-item\">\r\n                <div className=\"row\">\r\n                  {blogs.slice(0, 2).map((blog, index) => (\r\n                    <div key={index} className=\"col-xl-6 col-lg-6 col-md-6\">\r\n                      <div className=\"blog__item mb-30\">\r\n                        <div className=\"blog__thumb fix\">\r\n                          <Link href={`/blog-details/${blog.id}`}>\r\n                            <a className=\"w-img\">\r\n                              <img src={blog.img} alt=\"blog\" />\r\n                            </a>\r\n                          </Link>\r\n                        </div>\r\n                        <div className=\"blog__content\">\r\n                          <h4>\r\n                            <Link href={`/blog-details/${blog.id}`}>\r\n                              <a>{blog.title}</a>\r\n                            </Link>\r\n                          </h4>\r\n                          <div className=\"blog__meta\">\r\n                            <span>By <a href=\"#\">{blog.auhtor}</a></span>\r\n                            <span>/ {blog.date}</span>\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  ))}\r\n                </div>\r\n              </div>\r\n              <div className=\"postbox__line mt-65\"></div>\r\n              <div className=\"postbox__comments pt-90\">\r\n                <div className=\"postbox__comment-title mb-30\">\r\n                  <h3>Comments (32)</h3>\r\n                </div>\r\n                <div className=\"latest-comments mb-30\">\r\n                  <ul>\r\n                    {reviews.map((review, index) => (\r\n                      <li key={index} className={review.children ? 'children' : ''}>\r\n                        <div className=\"comments-box\">\r\n                          <div className=\"comments-avatar\">\r\n                            <img src={review.img} alt=\"\" />\r\n                          </div>\r\n                          <div className=\"comments-text\">\r\n                            <div className=\"avatar-name\">\r\n                              <h5>{review.name}</h5>\r\n                              <span> - {review.time} </span>\r\n                              <a className=\"reply\" href=\"#\">Leave Reply</a>\r\n                            </div>\r\n                            <div className=\"user-rating\">\r\n                              <ul>\r\n                                <li><a href=\"#\"><i className=\"fas fa-star\"></i></a></li>\r\n                                <li><a href=\"#\"><i className=\"fas fa-star\"></i></a></li>\r\n                                <li><a href=\"#\"><i className=\"fas fa-star\"></i></a></li>\r\n                                <li><a href=\"#\"><i className=\"fas fa-star\"></i></a></li>\r\n                                <li><a href=\"#\"><i className=\"fal fa-star\"></i></a></li>\r\n                              </ul>\r\n                            </div>\r\n                            <p>Many desktop publishing packages and web page editors now use Lorem Ipsum as their default model text, and a search for <span>“lorem ipsum”</span> will uncover many web sites still in their infancy. Various versions have evolved over the years, sometimes by accident, sometimes on purpose.</p>\r\n                          </div>\r\n                        </div>\r\n                      </li>\r\n                    ))}\r\n                  </ul>\r\n                </div>\r\n              </div>\r\n              <div className=\"postbox__line mb-95\"></div>\r\n              <div className=\"post-comments-form mb-100\">\r\n                <div className=\"post-comments-title mb-30\">\r\n                  <h3>Leave A Reply</h3>\r\n                </div>\r\n                {/* blog form start */}\r\n                <BlogForm />\r\n                {/* blog form start */}\r\n              </div>\r\n            </div>\r\n            <div className=\"col-xl-3 col-lg-4\">\r\n              <BlogSidebar />\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default BlogDetailsArea;\r\n","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-details\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-left-sidebar\\blog-left-sidebar.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-left-sidebar\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-no-sidebar\\blog-no-sidebar.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-no-sidebar\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\cart\\cart-area.jsx",["663"],[],"import Link from 'next/link';\r\nimport { useDispatch, useSelector } from 'react-redux';\r\nimport useCartInfo from '../../hooks/use-cart-info';\r\n\r\nimport { cartProducts, cart_product, clear_cart, decrease_quantity, remove_cart_product }\r\n  from '../../redux/features/cart-slice';\r\n\r\nconst CartArea = () => {\r\n  const cartItems = useSelector(cartProducts);\r\n  const dispatch = useDispatch();\r\n  const { total } = useCartInfo();\r\n  const handleChange = () => {};\r\n  const handleSubmit = e => e.preventDefault();\r\n  return (\r\n    <>\r\n      <section className=\"cart-area pt-100 pb-100\">\r\n        <div className=\"container\">\r\n          <div className=\"row\">\r\n            <div className=\"col-12\">\r\n              {cartItems.length === 0 &&\r\n                <div className='text-center'>\r\n                  <h3>Your cart is empty</h3>\r\n                  <button className=\"os-btn os-btn-2 mt-30\">Return to shop</button>\r\n                </div>\r\n              }\r\n              {cartItems.length > 0 && <form onSubmit={handleSubmit}>\r\n                <div className=\"table-content table-responsive\">\r\n                  <table className=\"table\">\r\n                    <thead>\r\n                      <tr>\r\n                        <th className=\"product-thumbnail\">Images</th>\r\n                        <th className=\"cart-product-name\">Product</th>\r\n                        <th className=\"product-price\">Unit Price</th>\r\n                        <th className=\"product-quantity\">Quantity</th>\r\n                        <th className=\"product-subtotal\">Total</th>\r\n                        <th className=\"product-remove\">Remove</th>\r\n                      </tr>\r\n                    </thead>\r\n                    <tbody>\r\n                      {cartItems.map((item, index) => (\r\n                        <tr key={index}>\r\n                          <td className=\"product-thumbnail\">\r\n                            <Link href={`/product-details/${item.id}`}>\r\n                              <a>\r\n                                <img src={item.img} alt=\"\" />\r\n                              </a>\r\n                            </Link>\r\n                          </td>\r\n                          <td className=\"product-name\">\r\n                            <Link href={`/product-details/${item.id}`}>\r\n                              <a>{item.title}</a>\r\n                            </Link>\r\n                          </td>\r\n                          <td className=\"product-price\"><span className=\"amount\">${item.price}</span></td>\r\n                          <td className=\"product-quantity\">\r\n                            <div className=\"cart-plus-minus\">\r\n                              <input type=\"text\" onChange={handleChange} value={item.quantity} />\r\n                              <div onClick={() => dispatch(decrease_quantity(item))} className=\"dec qtybutton\">-</div>\r\n                              <div onClick={() => dispatch(cart_product(item))} className=\"inc qtybutton\">+</div>\r\n                            </div>\r\n                          </td>\r\n                          <td className=\"product-subtotal\">\r\n                            <span className=\"amount\">${item.quantity * item.price}</span>\r\n                          </td>\r\n                          <td onClick={() => dispatch(remove_cart_product(item))} className=\"product-remove\">\r\n                            <button ><i className=\"fa fa-times\"></i></button>\r\n                          </td>\r\n                        </tr>\r\n                      ))}\r\n\r\n                    </tbody>\r\n                  </table>\r\n                </div>\r\n                <div className=\"row\">\r\n                  <div className=\"col-12\">\r\n                    <div className=\"coupon-all\">\r\n                      <div className=\"coupon\">\r\n                        <input required id=\"coupon_code\" className=\"input-text\" name=\"coupon_code\"\r\n                          placeholder=\"Coupon code\" type=\"text\" />\r\n                        <button className=\"os-btn os-btn-black\" name=\"apply_coupon\" type=\"submit\">Apply\r\n                          coupon</button>\r\n                      </div>\r\n                      <div className=\"coupon2\">\r\n                        <button onClick={() => dispatch(clear_cart())} className=\"os-btn os-btn-black\" \r\n                        name=\"update_cart\" type=\"button\">Clear cart</button>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n                <div className=\"row\">\r\n                  <div className=\"col-md-5 ms-auto\">\r\n                    <div className=\"cart-page-total\">\r\n                      <h2>Cart totals</h2>\r\n                      <ul className=\"mb-20\">\r\n                        <li>Subtotal <span>${total}</span></li>\r\n                        <li>Total <span>${total}</span></li>\r\n                      </ul>\r\n                      <Link href={'/checkout'}>\r\n                        <a className=\"os-btn\">Proceed to checkout</a>\r\n                      </Link>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              </form>}\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default CartArea;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\cart\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\checkout\\checkout-area.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\checkout\\coupon-area.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\checkout\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\banner\\banner-2.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\banner\\banner-3.jsx",["664"],[],"import Link from \"next/link\";\r\nimport { banners } from \"../../../data\";\r\n\r\nconst BannerThree = () => {\r\n  return (\r\n    <>\r\n      <div className=\"banner__area-df mt-10\">\r\n        {banners.slice(6, 9).map(banner => (\r\n          <div key={banner.id} className=\"banner__item-3 mb-30\">\r\n            <div className=\"banner__item-3-image m-img\">\r\n              <img src={banner.img} alt=\"\" />\r\n            </div>\r\n            <div className=\"banner__content-5\">\r\n              <h5>{banner.title}</h5>\r\n              <p>{banner.desc}</p>\r\n              <Link href=\"/shop-3-col\">\r\n                <a className=\"os-btn-5\">{banner.btnText}</a>\r\n              </Link>\r\n            </div>\r\n          </div>\r\n        ))}\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default BannerThree;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\banner\\banner.jsx",["665"],[],"import { banners } from \"../../../data\";\r\nimport Link from \"next/link\";\r\n\r\nconst Banner = ({ df, h4, home_six }) => {\r\n  return (\r\n    <>\r\n      <div className={`banner__area ${df ? 'pt-95' : ''} ${h4 ? 'pt-20' : ''} ${home_six ? 'pt-30' : ''}`}>\r\n        <div className={`container ${h4 ? 'custom-container' : ''}`}>\r\n          <div className={`${df ? '' : !h4 && !home_six && 'banner__inner p-relative mt--95'} \r\n        ${home_six ? 'banner__inner-2 p-relative' : ''}`}>\r\n            <div className=\"row\">\r\n              {banners.slice(h4 ? 3 : 0, h4 ? 6 : 3).map((banner, index) => (\r\n                <div key={index} className=\"col-xl-4 col-lg-4 col-md-6\">\r\n                  <div className=\"banner__item mb-30 p-relative\">\r\n                    <div className=\"banner__thumb fix\">\r\n                      <Link href=\"/shop\">\r\n                        <a className=\"w-img\">\r\n                          <img src={banner.img} alt=\"banner\" />\r\n                        </a>\r\n                      </Link>\r\n                    </div>\r\n                    <div className=\"banner__content p-absolute transition-3\">\r\n                      <h5>\r\n                        <Link href=\"/shop\">\r\n                          <a>{banner.title}</a>\r\n                        </Link>\r\n                      </h5>\r\n                      <Link href=\"/shop\">\r\n                        <a className=\"link-btn\">{banner.btnText}</a>\r\n                      </Link>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              ))}\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default Banner;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\blog\\blog-area.jsx",["666"],[],"import Slider from \"react-slick\";\r\nimport { blogs } from \"../../../data\";\r\nimport Link from 'next/link';\r\n\r\nconst blog_items = blogs.filter(blog => blog.blog_one);\r\n\r\n// slider setting\r\nconst settings = {\r\n  autoplay: true,\r\n  autoplaySpeed: 10000,\r\n  arrows: false,\r\n  infinite: true,\r\n  slidesToShow: 3,\r\n  slidesToScroll: 1,\r\n  responsive: [\r\n    {\r\n      breakpoint: 992,\r\n      settings: {\r\n        slidesToShow: 2,\r\n      }\r\n    },\r\n    {\r\n      breakpoint: 768,\r\n      settings: {\r\n        slidesToShow: 1,\r\n      }\r\n    },\r\n  ]\r\n};\r\n\r\n\r\nconst BlogArea = ({ home_three, h4 }) => {\r\n  return (\r\n    <>\r\n      <section className={`blog__area pb-70 ${home_three ? 'pt-90' : ''}`}>\r\n        <div className={`container ${h4 ? 'custom-container' : ''}`}>\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-12\">\r\n              <div className={`section__title-wrapper text-center mb-55 ${h4 ? 'p-relative' : ''}`}>\r\n                <div className=\"section__title mb-10\">\r\n                  <h2>Our Blog Posts</h2>\r\n                </div>\r\n                <div className=\"section__sub-title\">\r\n                  <p>Mirum est notare quam littera gothica quam nunc putamus parum claram!</p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-12\">\r\n              <div className=\"blog__slider owl-carousel\">\r\n\r\n                <Slider {...settings}>\r\n                  {\r\n                    blog_items.map((item, index) => {\r\n                      return <div key={index} className=\"blog__item mb-30\">\r\n                        <div className=\"blog__thumb fix\">\r\n                          <Link href={`/blog-details/${item.id}`}>\r\n                            <a className=\"w-img\">\r\n                              <img src={item.img} alt=\"blog\" />\r\n                            </a>\r\n                          </Link>\r\n                        </div>\r\n                        <div className=\"blog__content\">\r\n                          <h4>\r\n                            <Link href={`/blog-details/${item.id}`}>\r\n                              <a>{item.title}</a>\r\n                            </Link>\r\n                          </h4>\r\n                          <div className=\"blog__meta\">\r\n                            <span>By <a href=\"#\">{item.author}</a></span>\r\n                            <span>/ {item.date}</span>\r\n                          </div>\r\n                          <p>{item.desc}</p>\r\n                          <Link href={`/blog-details/${item.id}`}>\r\n                            <a className=\"os-btn\">read more</a>\r\n                          </Link>\r\n                        </div>\r\n                      </div>\r\n                    })\r\n                  }\r\n                </Slider>\r\n\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default BlogArea;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\blog\\blog-items.jsx",["667"],[],"import Link from 'next/link';\r\nimport React, { useEffect, useState } from 'react';\r\nimport ReactPaginate from 'react-paginate';\r\n\r\nconst BlogItems = ({ itemsPerPage, items }) => {\r\n  const [currentItems, setCurrentItems] = useState(null);\r\n  const [pageCount, setPageCount] = useState(0);\r\n  const [itemOffset, setItemOffset] = useState(0);\r\n\r\n  useEffect(() => {\r\n    const endOffset = itemOffset + itemsPerPage;\r\n    setCurrentItems(items.slice(itemOffset, endOffset));\r\n    setPageCount(Math.ceil(items.length / itemsPerPage));\r\n  }, [itemOffset, itemsPerPage, items]);\r\n\r\n  const handlePageClick = (event) => {\r\n    const newOffset = (event.selected * itemsPerPage) % items.length;\r\n    setItemOffset(newOffset);\r\n  };\r\n\r\n  return (\r\n    <>\r\n\r\n      <div className=\"blog__wrapper\">\r\n        {currentItems && currentItems.map((blog, index) => (\r\n          <div key={index} className=\"blog__item blog__border-bottom mb-60 pb-60\">\r\n            <div className=\"blog__thumb fix\">\r\n              <Link href={`/blog-details/${blog.id}`}>\r\n                <a className=\"w-img\">\r\n                  <img src={blog.img} alt=\"blog\" />\r\n                </a>\r\n              </Link>\r\n            </div>\r\n            <div className=\"blog__content\">\r\n              <h4 className=\"blog__title\">\r\n                <Link href={`/blog-details/${blog.id}`}>\r\n                  <a>{blog.title}</a>\r\n                </Link>\r\n              </h4>\r\n              <div className=\"blog__meta\">\r\n                <span>By <a href=\"#\">{blog.author}</a></span>\r\n                <span>/ {blog.date}</span>\r\n              </div>\r\n              <p>{blog.desc}</p>\r\n              <Link href={`/blog-details/${blog.id}`}>\r\n                <a className=\"os-btn\">read more</a>\r\n              </Link>\r\n            </div>\r\n          </div>\r\n        ))}\r\n      </div>\r\n\r\n      <div className=\"row mt-35\">\r\n        <div className=\"col-xl-12\">\r\n          <div className=\"shop-pagination-wrapper d-md-flex justify-content-between align-items-center\">\r\n\r\n            <div className=\"basic-pagination\">\r\n              <ReactPaginate\r\n                nextLabel={<><i className=\"fal fa-angle-right\"></i></>}\r\n                onPageChange={handlePageClick}\r\n                pageRangeDisplayed={3}\r\n                marginPagesDisplayed={2}\r\n                pageCount={pageCount}\r\n                previousLabel={<><i className=\"fal fa-angle-left\"></i></>}\r\n                pageClassName=\"page-item\"\r\n                pageLinkClassName=\"page-link\"\r\n                previousClassName=\"page-item\"\r\n                previousLinkClassName=\"page-link\"\r\n                nextClassName=\"page-item\"\r\n                nextLinkClassName=\"page-link\"\r\n                breakLabel=\"...\"\r\n                breakClassName=\"page-item\"\r\n                breakLinkClassName=\"page-link\"\r\n                containerClassName=\"pagination\"\r\n                activeClassName=\"active\"\r\n                renderOnZeroPageCount={null}\r\n              />\r\n            </div>\r\n\r\n            <div className=\"shop__header-left\">\r\n              <div className=\"show-text bottom\">\r\n                <span>Showing 1–{currentItems?.length} of {items?.length} results</span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n    </>\r\n  );\r\n};\r\n\r\nexport default BlogItems;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\blog\\blog-sidebar.jsx",["668","669"],[],"import Link from \"next/link\";\r\nimport { blogs } from \"../../../data\";\r\n\r\nconst categoryData = [\r\n  {\r\n    id: 'accessories',\r\n    title: 'Accessories',\r\n    target: 'collapseAccessories',\r\n    expanded: true,\r\n    show: true,\r\n    category_list: [\r\n      { list: 'Catagories 1' },\r\n      { list: 'Catagories 2' },\r\n      { list: 'Catagories 3' },\r\n    ]\r\n  },\r\n  {\r\n    id: 'cloth',\r\n    target: 'collapsecloth',\r\n    title: 'Clothing',\r\n    category_list: [\r\n      { list: 'Catagories 1' },\r\n      { list: 'Catagories 2' },\r\n      { list: 'Catagories 3' },\r\n    ]\r\n  },\r\n  {\r\n    id: \"men\",\r\n    target: 'collapsemen',\r\n    title: \"Men's\",\r\n    category_list: [\r\n      { list: 'Catagories 1' },\r\n      { list: 'Catagories 2' },\r\n      { list: 'Catagories 3' },\r\n    ]\r\n  },\r\n  {\r\n    id: \"music\",\r\n    target: 'collapsemusic',\r\n    title: \"Music\",\r\n    category_list: [\r\n      { list: 'Catagories 1' },\r\n      { list: 'Catagories 2' },\r\n      { list: 'Catagories 3' },\r\n    ]\r\n  },\r\n  {\r\n    id: \"decoration\",\r\n    target: 'collapseDecoration',\r\n    title: \"Decoration\",\r\n    category_list: [\r\n      { list: 'Catagories 1' },\r\n      { list: 'Catagories 2' },\r\n      { list: 'Catagories 3' },\r\n    ]\r\n  },\r\n]\r\n\r\nconst BlogSidebar = () => {\r\n  return (\r\n    <>\r\n      <div className=\"sidebar__wrapper\">\r\n        <div className=\"sidebar__widget mb-55\">\r\n          <div className=\"widget__search p-relative\">\r\n            <form action=\"#\">\r\n              <input type=\"text\" placeholder=\"Search...\" />\r\n              <button type=\"submit\"><i className=\"far fa-search\"></i></button>\r\n            </form>\r\n          </div>\r\n        </div>\r\n        <div className=\"sidebar__widget mb-55\">\r\n          <div className=\"sidebar__widget-title mb-25\">\r\n            <h3>Product Categories</h3>\r\n          </div>\r\n          <div className=\"sidebar__widget-content\">\r\n            <div className=\"categories\">\r\n              <div id=\"accordion\">\r\n                {categoryData.map((category, index) => (\r\n                  <div key={index} className=\"card\">\r\n                    <div className=\"card-header white-bg\" id={category.id}>\r\n                      <h5 className=\"mb-0\">\r\n                        <button className={`shop-accordion-btn ${category.show ? '' : 'collapsed'}`} data-bs-toggle=\"collapse\"\r\n                          data-bs-target={`#${category.target}`} aria-expanded={category.expanded ? 'true' : 'false'} aria-controls={`${category.target}`}>\r\n                          {category.title}\r\n                        </button>\r\n                      </h5>\r\n                    </div>\r\n\r\n                    <div id={category.target} className={`collapse ${category.show ? 'show' : ''}`}\r\n                      aria-labelledby={category.id} data-bs-parent=\"#accordion\">\r\n                      <div className=\"card-body\">\r\n                        <div className=\"categories__list\">\r\n                          <ul>\r\n                            {category.category_list.map((list, index) => (\r\n                              <li onClick={() => dispatch(category_product(list.list))} key={index}>\r\n                                <a href=\"#\">{list.list}</a>\r\n                              </li>\r\n                            ))}\r\n                          </ul>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                ))}\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div className=\"sidebar__widget mb-55\">\r\n          <div className=\"sidebar__widget-title mb-25\">\r\n            <h3>Latest Posts</h3>\r\n          </div>\r\n          <div className=\"sidebar__widget-content\">\r\n            <div className=\"rc__post-wrapper\">\r\n              <ul>\r\n                {blogs.slice(0, 3).map((blog, index) => (\r\n                  <li key={index} className=\"d-flex\">\r\n                    <div className=\"rc__post-thumb mr-20 \">\r\n                      <Link href={`/blog-details/${blog.id}`}>\r\n                        <a>\r\n                          <img src={blog.img} alt=\"blog-1\" />\r\n                        </a>\r\n                      </Link>\r\n                    </div>\r\n                    <div className=\"rc__post-content\">\r\n                      <h6>\r\n                        <Link href={`/blog-details/${blog.id}`}>\r\n                          <a>{blog.title}</a>\r\n                        </Link>\r\n                      </h6>\r\n                      <div className=\"rc__meta\">\r\n                        <span> {blog.date}</span>\r\n                      </div>\r\n                    </div>\r\n                  </li>\r\n                ))}\r\n              </ul>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div className=\"sidebar__widget mb-55\">\r\n          <div className=\"sidebar__widget-title mb-25\">\r\n            <h3>Recent Comments</h3>\r\n          </div>\r\n          <div className=\"sidebar__widget-content\">\r\n            <div className=\"rc__comments\">\r\n              <ul>\r\n                <RecentComment name={'Salim Rana'} />\r\n                <RecentComment name={'Shahnewaz Sakil'} />\r\n                <RecentComment name={'Naim Ahmed'} />\r\n              </ul>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div className=\"sidebar__widget mb-55\">\r\n          <div className=\"sidebar__widget-title mb-25\">\r\n            <h3>Archives</h3>\r\n          </div>\r\n          <div className=\"sidebar__widget-content\">\r\n            <div className=\"sidebar__links\">\r\n              <ul>\r\n                <li><a href=\"#\">December 2013</a></li>\r\n                <li><a href=\"#\"> November 2013</a></li>\r\n                <li><a href=\"#\"> September 2013</a></li>\r\n                <li><a href=\"#\">November 2012</a></li>\r\n              </ul>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div className=\"sidebar__widget mb-55\">\r\n          <div className=\"sidebar__widget-title mb-25\">\r\n            <h3>Meta</h3>\r\n          </div>\r\n          <div className=\"sidebar__widget-content\">\r\n            <div className=\"sidebar__links\">\r\n              <ul>\r\n                <li><a href=\"#\">Log in</a></li>\r\n                <li><a href=\"#\"> Entries RSS</a></li>\r\n                <li><a href=\"#\"> Comments RSS</a></li>\r\n                <li><a href=\"#\">WordPress.org</a></li>\r\n              </ul>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default BlogSidebar;\r\n\r\n\r\nconst RecentComment = ({ name }) => {\r\n  return (\r\n    <li className=\"d-flex mb-20\">\r\n      <div className=\"rc__comments-avater mr-15\">\r\n        <img src=\"/assets/img/blog/comments/avater-3.png\" alt=\"\" />\r\n      </div>\r\n      <div className=\"rc__comments-content\">\r\n        <h6>{name}</h6>\r\n        <p>Hi, this is a comment....</p>\r\n        <span>on <span className=\"highlight comment\"> Hello world!</span></span>\r\n      </div>\r\n    </li>\r\n  )\r\n}","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\brands\\brands-2.jsx",["670"],[],"import Slider from \"react-slick\";\r\n\r\nimport { brands } from \"../../../data\";\r\nimport { SampleNextArrow, SamplePrevArrow } from \"../../../utils/slider-arrow\";\r\n\r\n\r\nconst settings = {\r\n  autoplay: true,\r\n  autoplaySpeed: 10000,\r\n  nextArrow: <SampleNextArrow />,\r\n  prevArrow: <SamplePrevArrow />,\r\n  infinite: true,\r\n  slidesToShow: 5,\r\n  slidesToScroll: 1,\r\n  responsive: [\r\n    {\r\n      breakpoint: 1200,\r\n      settings: {\r\n        slidesToShow: 4,\r\n      }\r\n    },\r\n    {\r\n      breakpoint: 992,\r\n      settings: {\r\n        slidesToShow: 3,\r\n      }\r\n    },\r\n    {\r\n      breakpoint: 767,\r\n      settings: {\r\n        slidesToShow: 2,\r\n      }\r\n    },\r\n    {\r\n      breakpoint: 576,\r\n      settings: {\r\n        slidesToShow: 1,\r\n      }\r\n    },\r\n  ]\r\n};\r\n\r\n\r\nconst Brands = () => {\r\n  return (\r\n    <>\r\n      <div className=\"brand__area pb-90\">\r\n        <div className=\"container custom-container-2\">\r\n          <div className=\"brand__slider-active slick-carousel\">\r\n\r\n            <Slider {...settings}>\r\n              {\r\n                brands.map((item, index) => {\r\n                  return <div key={item.id} className=\"brand__slider-item\">\r\n                    <div className=\"brand__image\">\r\n                      <img src={item.img} alt=\"client\" />\r\n                    </div>\r\n                  </div>\r\n                })\r\n              }\r\n            </Slider>\r\n\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default Brands;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\brands\\brands.jsx",["671"],[],"import Slider from \"react-slick\";\r\nimport { brands } from \"../../../data\";\r\n\r\nconst settings = {\r\n  autoplay: true,\r\n  autoplaySpeed: 10000,\r\n  arrows: false,\r\n  infinite: true,\r\n  slidesToShow: 5,\r\n  slidesToScroll: 1,\r\n  responsive: [\r\n    {\r\n      breakpoint: 1200,\r\n      settings: {\r\n        slidesToShow: 4,\r\n      }\r\n    },\r\n    {\r\n      breakpoint: 992,\r\n      settings: {\r\n        slidesToShow: 3,\r\n      }\r\n    },\r\n    {\r\n      breakpoint: 767,\r\n      settings: {\r\n        slidesToShow: 2,\r\n      }\r\n    },\r\n    {\r\n      breakpoint: 576,\r\n      settings: {\r\n        slidesToShow: 1,\r\n      }\r\n    },\r\n  ]\r\n};\r\n\r\nconst Brands = ({df}) => {\r\n  return (\r\n    <>\r\n      <section className={`client__area ${df ? '' : 'pt-15 pb-140'}`}>\r\n        <div className=\"container\">\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-12\">\r\n              <div className={`client__slider ${df ? 'pt-80 pb-80 border-top-1' : ''} text-center`}>\r\n                <Slider {...settings}>\r\n                  {\r\n                    brands.map((item, index) => {\r\n                      return <div key={item.id} className=\"client__thumb\">\r\n                        <a href=\"#\">\r\n                          <img src={item.img} alt=\"client\" />\r\n                        </a>\r\n                      </div>\r\n                    })\r\n                  }\r\n                </Slider>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default Brands;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\breadcrumb.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\cart.jsx",["672"],[],"import Link from 'next/link';\r\nimport { useDispatch, useSelector } from 'react-redux';\r\nimport useCartInfo from '../../hooks/use-cart-info';\r\n\r\nimport { remove_cart_product } from '../../redux/features/cart-slice';\r\n\r\nconst Cart = () => {\r\n  const cartItems = useSelector(state => state.cart.cartProducts);\r\n  const dispatch = useDispatch();\r\n  const { total } = useCartInfo();\r\n\r\n  return (\r\n    <>\r\n      <div className=\"mini-cart\">\r\n        {cartItems.length === 0 && <h5>Your cart is empty</h5>}\r\n        {cartItems.length >= 1 && <div className=\"mini-cart-inner\">\r\n          <ul className={`mini-cart-list ${cartItems.length > 2 ? 'slider-height' : ''} \r\n          ${cartItems.length > 1 ? 'slider-height-2' : ''}`}>\r\n\r\n            {cartItems.map((item, index) => (\r\n              <li key={index}>\r\n                <div className=\"cart-img f-left\">\r\n                  <Link href={`/product-details/${item.id}`}>\r\n                    <a>\r\n                      <img src={item.img} alt=\"\" />\r\n                    </a>\r\n                  </Link>\r\n                </div>\r\n                <div className=\"cart-content f-left text-start\">\r\n                  <h5>\r\n                    <Link href={`/product-details/${item.id}`}>\r\n                      <a>{item.title} </a>\r\n                    </Link>\r\n                  </h5>\r\n                  <div className=\"cart-price\">\r\n                    <span className=\"ammount\">{item.quantity} <i className=\"fal fa-times\"></i></span>\r\n                    <span className=\"price\">$ {item.price}</span>\r\n                  </div>\r\n                </div>\r\n                <div className=\"del-icon f-right mt-30\">\r\n                  <button onClick={() => dispatch(remove_cart_product(item))}>\r\n                    <i className=\"fal fa-times\"></i>\r\n                  </button>\r\n                </div>\r\n              </li>\r\n            ))}\r\n\r\n          </ul>\r\n          <div className=\"total-price d-flex justify-content-between mb-30\">\r\n            <span>Subtotal:</span>\r\n            <span>${parseFloat(total)}</span>\r\n          </div>\r\n          <div className=\"checkout-link\">\r\n            <Link href={'/cart'}>\r\n              <a className=\"os-btn\">view Cart</a>\r\n            </Link>\r\n            <Link href={'/checkout'}>\r\n              <a className=\"os-btn os-btn-black\">Checkout</a>\r\n            </Link>\r\n          </div>\r\n        </div>}\r\n\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default Cart;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\filtering\\product-brands.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\filtering\\product-categories.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\filtering\\product-color.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\filtering\\product-feature.jsx",["673"],[],"import { selectProducts } from '../../../redux/features/product-slice';\r\nimport { useSelector } from 'react-redux';\r\nimport Link from 'next/link';\r\n\r\nconst ProductFeature = () => {\r\n  const products = useSelector(selectProducts);\r\n  const featurePrd = products.map(prd => prd.product).flat().filter(item => item.feature_prd).slice(0, 2);\r\n\r\n  return (\r\n    <>\r\n      <div className=\"sidebar__widget\">\r\n        <div className=\"sidebar__widget-title mb-30\">\r\n          <h3>Featured Products</h3>\r\n        </div>\r\n        <div className=\"sidebar__widget-content\">\r\n          <div className=\"features__product\">\r\n            <ul>\r\n              {featurePrd.map((product, index) => (\r\n                <li key={index} className=\"mb-20\">\r\n                  <div className=\"featires__product-wrapper d-flex\">\r\n                    <div className=\"features__product-thumb mr-15\">\r\n                      <Link href={`/product-details/${product.id}`}>\r\n                        <a>\r\n                          <img src={product.img} alt=\"pro-sm-1\" />\r\n                        </a>\r\n                      </Link>\r\n                    </div>\r\n                    <div className=\"features__product-content\">\r\n                      <h5>\r\n                        <Link href={`/product-details/${product.id}`}>\r\n                          <a>{product.title}</a>\r\n                        </Link>\r\n                      </h5>\r\n                      <div className=\"price\">\r\n                        <span>${product.price}</span>\r\n                        {product.old_price && <span className=\"price-old\">${product.old_price}</span>}\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </li>\r\n              ))}\r\n            </ul>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default ProductFeature;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\filtering\\product-price.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\filtering\\product-size.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\form\\blog-form.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\form\\contact-form.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\form\\error-msg.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\form\\login-form.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\form\\register-form.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\form\\validation-schema.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\hero-slider.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\modal\\product-modal.jsx",["674","675"],[],"import Link from \"next/link\";\r\nimport { useDispatch } from \"react-redux\";\r\n\r\nimport useGlobalContext from \"../../../hooks/use-context\";\r\nimport { cart_product, decrease_quantity } from \"../../../redux/features/cart-slice\";\r\n\r\nconst ProductModal = () => {\r\n  const {product} = useGlobalContext()\r\n  const dispatch = useDispatch();\r\n  const handleChange = () => {};\r\n  const handleSubmit = e =>  e.preventDefault()\r\n\r\n \r\n  return (\r\n    <>\r\n      <div className=\"modal fade\" id=\"productModalId\" tabIndex=\"-1\" role=\"dialog\" aria-hidden=\"true\">\r\n        <div className=\"modal-dialog modal-dialog-centered product-modal\" role=\"document\">\r\n          <div className=\"modal-content\">\r\n            <div className=\"product__modal-wrapper p-relative\">\r\n              <div className=\"product__modal-close p-absolute\">\r\n                <button data-bs-dismiss=\"modal\"><i className=\"fal fa-times\"></i></button>\r\n              </div>\r\n              <div className=\"product__modal-inner\">\r\n                <div className=\"row\">\r\n                  <div className=\"col-xl-5 col-lg-5 col-md-6 col-sm-12 col-12\">\r\n                    <div className=\"product__modal-box\">\r\n                      <div className=\"tab-content mb-20\" id=\"nav-tabContent\">\r\n                        {product?.images?.map((img, index) => (\r\n                          <div key={index} className={`tab-pane fade ${index === 0 ? 'show active' : ''} `}\r\n                            id={`nav-${index}`} role=\"tabpanel\" aria-labelledby={`nav-${index}-tab`}>\r\n                            <div className=\"product__modal-img w-img\">\r\n                              <img src={img.src} alt=\"\" />\r\n                            </div>\r\n                          </div>\r\n                        ))}\r\n                      </div>\r\n\r\n                      <nav>\r\n                        <div className=\"nav nav-tabs justify-content-between\" id=\"nav-tab\" role=\"tablist\">\r\n                          {product?.images?.map((img, index) => (\r\n                            <a key={index} className={`nav-item nav-link ${index === 0 ? 'active' : ''}`}\r\n                              id={`nav-${index}-tab`} data-bs-toggle=\"tab\" href={`#nav-${index}`}\r\n                              role=\"tab\" aria-controls={`nav-${index}`}\r\n                              aria-selected={index === 0 ? 'true' : 'false'}>\r\n                              <div className=\"product__nav-img w-img\">\r\n                                <img src={img.src} alt=\"\" />\r\n                              </div>\r\n                            </a>\r\n                          ))}\r\n                        </div>\r\n                      </nav>\r\n                    </div>\r\n                  </div>\r\n                  <div className=\"col-xl-7 col-lg-7 col-md-6 col-sm-12 col-12\">\r\n                    <div className=\"product__modal-content\">\r\n                      <h4>\r\n                        <Link href={`/product-details/${product?.id}`}>\r\n                          <a>{product?.title}</a>\r\n                        </Link>\r\n                      </h4>\r\n                      <div className=\"rating rating-shop mb-15\">\r\n                        <ul>\r\n                          <li><span><i className=\"fas fa-star\"></i></span></li>\r\n                          <li><span><i className=\"fas fa-star\"></i></span></li>\r\n                          <li><span><i className=\"fas fa-star\"></i></span></li>\r\n                          <li><span><i className=\"fas fa-star\"></i></span></li>\r\n                          <li><span><i className=\"fal fa-star\"></i></span></li>\r\n                        </ul>\r\n                        <span className=\"rating-no ml-10\">\r\n                          {product?.rating} rating(s)\r\n                        </span>\r\n                      </div>\r\n                      <div className=\"product__price-2 mb-25\">\r\n                        <span>${product?.price}</span>\r\n                        <span className=\"old-price\">${product?.old_price}</span>\r\n                      </div>\r\n                      <div className=\"product__modal-des mb-30\">\r\n                        <p>{product.desc}</p>\r\n                      </div>\r\n                      <div className=\"product__modal-form\">\r\n                        <form onSubmit={handleSubmit}>\r\n                          <div className=\"product__modal-input size mb-20\">\r\n                            <label>Size <i className=\"fas fa-star-of-life\"></i></label>\r\n                            <select>\r\n                              <option>- Please select -</option>\r\n                              {product?.sizes?.map((size, index) => (\r\n                                <option key={index}>{size}</option>\r\n                              ))}\r\n                            </select>\r\n                          </div>\r\n                          <div className=\"product__modal-input color mb-20\">\r\n                            <label>Color <i className=\"fas fa-star-of-life\"></i></label>\r\n                            <select>\r\n                              <option>- Please select -</option>\r\n                              {product?.colors?.map((color, index) => (\r\n                                <option key={index}>{color}</option>\r\n                              ))}\r\n                            </select>\r\n                          </div>\r\n              \r\n                          <div className=\"pro-quan-area d-lg-flex align-items-center\">\r\n                            <div className=\"pro-cart-btn\">\r\n                              <button onClick={() => dispatch(cart_product(product))}\r\n                                className=\"os-btn os-btn-black os-btn-3 mr-10 text-center\">+ Add to Cart</button>\r\n                            </div>\r\n                          </div>\r\n                        </form>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default ProductModal;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\modal\\video-modal.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\pagination.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\product\\feature-product.jsx",["676"],[],"import React from 'react';\r\nimport Link from 'next/link';\r\n\r\nconst FeatureProduct = ({ index, product, h4 }) => {\r\n  return (\r\n    <>\r\n      <div className=\"col-xl-6 col-lg-6\">\r\n        <div className={`banner__item-2 ${index === 0 ? ' banner-right' : ' banner-left'} p-relative mb-30 pr-15`}>\r\n          <div className=\"banner__thumb fix\">\r\n            <Link href={`/product-details/${product.id}`}>\r\n              <a className=\"w-img\">\r\n                <img src={product.img} alt=\"banner\" />\r\n              </a>\r\n            </Link>\r\n          </div>\r\n          <div className={`banner__content-2 ${h4 ? 'banner__content-4' : ''} p-absolute transition-3`}>\r\n            <span>{product.sm_title}</span>\r\n            <h4>\r\n              <Link href={`/product-details/${product.id}`}>\r\n                <a>{product.title}</a>\r\n              </Link>\r\n            </h4>\r\n            {!h4 && <p>{product.desc}</p>}\r\n            {h4 && <p>{product.desc_2}</p>}\r\n            <Link href={`/product-details/${product.id}`}>\r\n              <a className=\"os-btn os-btn-2\">buy now /\r\n                <span>${parseFloat(product.price)}</span>\r\n              </a>\r\n            </Link>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default FeatureProduct;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\product\\product-details.jsx",["677","678","679","680","681"],[],"import { useDispatch, useSelector } from 'react-redux';\r\nimport Link from 'next/link';\r\nimport { cartProducts, cart_product, decrease_quantity } from '../../../redux/features/cart-slice';\r\nimport { selectProducts, single_product } from '../../../redux/features/product-slice';\r\nimport ProductModal from '../modal/product-modal';\r\nimport { add_to_wishlist } from '../../../redux/features/wishlist-slice';\r\n\r\nconst ProductDetails = ({ product }) => {\r\n  const dispatch = useDispatch();\r\n  const cartItems = useSelector(cartProducts)\r\n  const selectedItem = cartItems.find(item => Number(item.id) === Number(product.id));\r\n  return (\r\n    <>\r\n      <section className=\"shop__area pb-65\">\r\n        <div className=\"shop__top grey-bg-6 pt-100 pb-90\">\r\n          <div className=\"container\">\r\n            <div className=\"row\">\r\n              <div className=\"col-xl-6 col-lg-6\">\r\n                <div className=\"product__modal-box d-flex\">\r\n                  <div className=\"product__modal-nav mr-20\">\r\n                    <nav>\r\n                      <div className=\"nav nav-tabs\" id=\"product-details\" role=\"tablist\">\r\n                        {product?.images?.map((img, index) => (\r\n                          <a key={index} className={`nav-item nav-link mb-20 ${index === 0 ? 'active' : ''}`}\r\n                            id={`nav-${index}-tab`} data-bs-toggle=\"tab\" href={`#nav-${index}`}\r\n                            role=\"tab\" aria-controls={`nav-${index}`}\r\n                            aria-selected={index === 0 ? 'true' : 'false'}>\r\n                            <div className=\"product__nav-img w-img\">\r\n                              <img src={img.src} alt=\"\" />\r\n                            </div>\r\n                          </a>\r\n                        ))}\r\n                      </div>\r\n                    </nav>\r\n                  </div>\r\n\r\n                  <div className=\"tab-content mb-20\" id=\"product-detailsContent\">\r\n\r\n                    {product?.images?.map((img, index) => (\r\n                      <div key={index} className={`tab-pane fade ${index === 0 ? 'show active' : ''} `}\r\n                        id={`nav-${index}`} role=\"tabpanel\" aria-labelledby={`nav-${index}-tab`}>\r\n                        <div className=\"product__modal-img w-img\">\r\n                          <img src={img.src} alt=\"\" />\r\n                          {product.product_sale && <div className=\"product__sale \">\r\n                            <span className=\"new\">new</span>\r\n                            <span className=\"percent\">-16%</span>\r\n                          </div>}\r\n                        </div>\r\n                      </div>\r\n                    ))}\r\n\r\n                  </div>\r\n                </div>\r\n              </div>\r\n              <div className=\"col-xl-6 col-lg-6\">\r\n                <div className=\"product__modal-content product__modal-content-2\">\r\n                  <h4>\r\n                    <Link href={`/product-details/${product?.id}`}>\r\n                      <a>{product?.title}</a>\r\n                    </Link>\r\n                  </h4>\r\n                  <div className=\"rating rating-shop mb-15\">\r\n                    <ul>\r\n                      <li><span><i className=\"fas fa-star\"></i></span></li>\r\n                      <li><span><i className=\"fas fa-star\"></i></span></li>\r\n                      <li><span><i className=\"fas fa-star\"></i></span></li>\r\n                      <li><span><i className=\"fas fa-star\"></i></span></li>\r\n                      <li><span><i className=\"fal fa-star\"></i></span></li>\r\n                    </ul>\r\n                    <span className=\"rating-no ml-10 rating-left\">\r\n                      {product?.rating} rating(s)\r\n                    </span>\r\n                    <span className=\"review rating-left\"><a href=\"#\">Add your Review</a></span>\r\n                  </div>\r\n                  <div className=\"product__price-2 mb-25\">\r\n                    <span>${product?.price}</span>\r\n                    {product.old_price && <span className=\"old-price\">${product?.old_price}</span>}\r\n                  </div>\r\n                  <div className=\"product__modal-des mb-30\">\r\n                    <p>{product.desc}</p>\r\n                  </div>\r\n                  <div className=\"product__modal-form mb-30\">\r\n                    <form action=\"#\">\r\n                      <div className=\"product__modal-input size mb-20\">\r\n                        <label>Size <i className=\"fas fa-star-of-life\"></i></label>\r\n                        <select>\r\n                          <option>- Please select -</option>\r\n                          {product?.sizes?.map((size, index) => (\r\n                            <option key={index}>{size}</option>\r\n                          ))}\r\n                        </select>\r\n                      </div>\r\n                      <div className=\"product__modal-input color mb-20\">\r\n                        <label>Color <i className=\"fas fa-star-of-life\"></i></label>\r\n                        <select>\r\n                          <option>- Please select -</option>\r\n                          {product?.colors?.map((color, index) => (\r\n                            <option key={index}>{color}</option>\r\n                          ))}\r\n                        </select>\r\n                      </div>\r\n                      <div className=\"product__modal-required mb-5\">\r\n                        <span >Repuired Fiields *</span>\r\n                      </div>\r\n                      <div className=\"pro-quan-area d-sm-flex align-items-center\">\r\n                        <div className=\"product-quantity-title\">\r\n                          <label>Quantity</label>\r\n                        </div>\r\n                        <div className=\"product-quantity mr-20 mb-20\">\r\n                          <div className=\"cart-plus-minus\">\r\n                            <input type=\"text\" value={selectedItem?.quantity ? selectedItem?.quantity : 0} />\r\n                            <div onClick={() => dispatch(decrease_quantity(product))} className=\"dec qtybutton\">-</div>\r\n                            <div onClick={() => dispatch(cart_product(product))} className=\"inc qtybutton\">+</div>\r\n                          </div>\r\n                        </div>\r\n                        <div className=\"pro-cart-btn\">\r\n                          <a href=\"#\" onClick={() => dispatch(cart_product(product))}\r\n                            className=\"add-cart-btn mb-20\">+ Add to Cart</a>\r\n                        </div>\r\n                      </div>\r\n                    </form>\r\n                  </div>\r\n                  <div className=\"product__tag mb-25\">\r\n                    <span>Category:</span>\r\n                    <span><a href=\"#\">Accessories,</a></span>\r\n                    <span><a href=\"#\">Gaming,</a></span>\r\n                    <span><a href=\"#\">PC Computers,</a></span>\r\n                    <span><a href=\"#\">Ultrabooks</a></span>\r\n                  </div>\r\n                  <div className=\"product__share\">\r\n                    <span>Share :</span>\r\n                    <ul>\r\n                      <li><a href=\"#\"><i className=\"fab fa-facebook-f\"></i></a></li>\r\n                      <li><a href=\"#\"><i className=\"fab fa-twitter\"></i></a></li>\r\n                      <li><a href=\"#\"><i className=\"fab fa-behance\"></i></a></li>\r\n                      <li><a href=\"#\"><i className=\"fab fa-linkedin-in\"></i></a></li>\r\n                      <li><a href=\"#\"><i className=\"fab fa-youtube\"></i></a></li>\r\n                    </ul>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div className=\"shop__bottom\">\r\n          <div className=\"container\">\r\n            <div className=\"row\">\r\n              <div className=\"col-xl-12\">\r\n                <div className=\"product__details-tab\">\r\n                  <div className=\"product__details-tab-nav text-center mb-45\">\r\n                    <nav>\r\n                      <div className=\"nav nav-tabs justify-content-start justify-content-sm-center\" id=\"pro-details\" role=\"tablist\">\r\n                        <a className=\"nav-item nav-link active\" id=\"des-tab\" data-bs-toggle=\"tab\" href=\"#des\" role=\"tab\" aria-controls=\"des\" aria-selected=\"true\">Description</a>\r\n                        <a className=\"nav-item nav-link\" id=\"add-tab\" data-bs-toggle=\"tab\" href=\"#add\" role=\"tab\" aria-controls=\"add\" aria-selected=\"false\">Additional Information</a>\r\n                        <a className=\"nav-item nav-link\" id=\"review-tab\" data-bs-toggle=\"tab\" href=\"#review\" role=\"tab\" aria-controls=\"review\" aria-selected=\"false\">Reviews (4)</a>\r\n                      </div>\r\n                    </nav>\r\n                  </div>\r\n                  <div className=\"tab-content\" id=\"pro-detailsContent\">\r\n                    <div className=\"tab-pane fade show active\" id=\"des\" role=\"tabpanel\">\r\n                      <div className=\"product__details-des\">\r\n                        <p>Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the {\"industry's\"} standard dummy text ever since the 1500s, when anunknown printer took a galley of type and scrambled it to make a type specimen book. It has survived not only five centuries, but also the leap into electronic typesetting, remaining essentially unchanged. It was popularised in the 1960s with the release of Letraset sheets containing Lorem Ipsum passages.</p>\r\n\r\n                        <div className=\"product__details-des-list mb-20\">\r\n                          <ul>\r\n                            <li><span>Claritas est etiam processus dynamicus.</span></li>\r\n                            <li><span>Qui sequitur mutationem consuetudium lectorum.</span></li>\r\n                            <li><span>Claritas est etiam processus dynamicus.</span></li>\r\n                            <li><span>Qui sequitur mutationem consuetudium lectorum.</span></li>\r\n                            <li><span>Claritas est etiam processus dynamicus.</span></li>\r\n                            <li><span>Qui sequitur mutationem consuetudium lectorum.</span></li>\r\n                          </ul>\r\n                        </div>\r\n                        <p>It has survived not only five centuries, but also the leap into electronic typesetting, remaining essentially unchanged. It was popularised in the 1960s with the release.</p>\r\n                      </div>\r\n                    </div>\r\n                    <div className=\"tab-pane fade\" id=\"add\" role=\"tabpanel\">\r\n                      <div className=\"product__details-add\">\r\n                        <ul>\r\n                          <li><span>Weight</span></li>\r\n                          <li><span>{product?.weight} KG</span></li>\r\n                          <li><span>Dimention</span></li>\r\n                          <li><span>{product?.dimension}</span></li>\r\n                          <li><span>Size</span></li>\r\n                          <li><span>XL, XXL, LG, SM, MD</span></li>\r\n                        </ul>\r\n                      </div>\r\n                    </div>\r\n                    <div className=\"tab-pane fade\" id=\"review\" role=\"tabpanel\">\r\n                      <div className=\"product__details-review\">\r\n                        <div className=\"postbox__comments\">\r\n                          <div className=\"postbox__comment-title mb-30\">\r\n                            <h3>Reviews (32)</h3>\r\n                          </div>\r\n                          <div className=\"latest-comments mb-30\">\r\n                            <ul>\r\n                              {product?.reviews?.map((review, index) => (\r\n                                <li key={index} className={review.children ? 'children' : ''}>\r\n                                  <div className=\"comments-box\">\r\n                                    <div className=\"comments-avatar\">\r\n                                      <img src={review.img} alt=\"\" />\r\n                                    </div>\r\n                                    <div className=\"comments-text\">\r\n                                      <div className=\"avatar-name\">\r\n                                        <h5>{review.name}</h5>\r\n                                        <span> - {review.time} </span>\r\n                                        <a className=\"reply\" href=\"#\">Leave Reply</a>\r\n                                      </div>\r\n                                      <div className=\"user-rating\">\r\n                                        <ul>\r\n                                          <li><a href=\"#\"><i className=\"fas fa-star\"></i></a></li>\r\n                                          <li><a href=\"#\"><i className=\"fas fa-star\"></i></a></li>\r\n                                          <li><a href=\"#\"><i className=\"fas fa-star\"></i></a></li>\r\n                                          <li><a href=\"#\"><i className=\"fas fa-star\"></i></a></li>\r\n                                          <li><a href=\"#\"><i className=\"fal fa-star\"></i></a></li>\r\n                                        </ul>\r\n                                      </div>\r\n                                      <p>Many desktop publishing packages and web page editors now use Lorem Ipsum as their default model text, and a search for <span>“lorem ipsum”</span> will uncover many web sites still in their infancy. Various versions have evolved over the years, sometimes by accident, sometimes on purpose.</p>\r\n                                    </div>\r\n                                  </div>\r\n                                </li>\r\n                              ))}\r\n\r\n                            </ul>\r\n                          </div>\r\n                        </div>\r\n                        <div className=\"post-comments-form mb-100\">\r\n                          <div className=\"post-comments-title mb-30\">\r\n                            <h3>Your Review</h3>\r\n                            <div className=\"post-rating\">\r\n                              <span>Your Rating :</span>\r\n                              <ul>\r\n                                <li>\r\n                                  <a href=\"#\">\r\n                                    <i className=\"fal fa-star\"></i>\r\n                                  </a>\r\n                                </li>\r\n                                <li>\r\n                                  <a href=\"#\">\r\n                                    <i className=\"fal fa-star\"></i>\r\n                                  </a>\r\n                                </li>\r\n                                <li>\r\n                                  <a href=\"#\">\r\n                                    <i className=\"fal fa-star\"></i>\r\n                                  </a>\r\n                                </li>\r\n                                <li>\r\n                                  <a href=\"#\">\r\n                                    <i className=\"fal fa-star\"></i>\r\n                                  </a>\r\n                                </li>\r\n                                <li>\r\n                                  <a href=\"#\">\r\n                                    <i className=\"fal fa-star\"></i>\r\n                                  </a>\r\n                                </li>\r\n                              </ul>\r\n                            </div>\r\n                          </div>\r\n                          <form id=\"contacts-form\" className=\"conatct-post-form\" action=\"#\">\r\n                            <div className=\"row\">\r\n                              <div className=\"col-xl-6 col-lg-6 col-md-6\">\r\n                                <div className=\"contact-icon p-relative contacts-name\">\r\n                                  <input type=\"text\" placeholder=\"Name\" />\r\n                                </div>\r\n                              </div>\r\n                              <div className=\"col-xl-6 col-lg-6 col-md-6\">\r\n                                <div className=\"contact-icon p-relative contacts-name\">\r\n                                  <input type=\"email\" placeholder=\"Email\" />\r\n                                </div>\r\n                              </div>\r\n                              <div className=\"col-xl-12\">\r\n                                <div className=\"contact-icon p-relative contacts-email\">\r\n                                  <input type=\"text\" placeholder=\"Subject\" />\r\n                                </div>\r\n                              </div>\r\n                              <div className=\"col-xl-12\">\r\n                                <div className=\"contact-icon p-relative contacts-message\">\r\n                                  <textarea name=\"comments\" id=\"comments\" cols=\"30\" rows=\"10\"\r\n                                    placeholder=\"Comments\"></textarea>\r\n                                </div>\r\n                              </div>\r\n                              <div className=\"col-xl-12\">\r\n                                <button className=\"os-btn os-btn-black\" type=\"submit\">Post comment</button>\r\n                              </div>\r\n                            </div>\r\n                          </form>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n      {/* RelatedProducts start */}\r\n      <RelatedProducts />\r\n      {/* RelatedProducts end */}\r\n\r\n      {/* product modal start */}\r\n      <ProductModal />\r\n      {/* product modal end */}\r\n    </>\r\n  );\r\n};\r\n\r\nexport default ProductDetails;\r\n\r\n\r\n\r\nconst RelatedProducts = () => {\r\n  const trendingProducts = useSelector(selectProducts)\r\n    .filter(item => item.trending)\r\n    .map(product => product.product)\r\n    .flat()\r\n    .slice(0, 4);\r\n  const dispatch = useDispatch();\r\n  return (\r\n    <>\r\n      <section className=\"related__product pb-60\">\r\n        <div className=\"container\">\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-12\">\r\n              <div className=\"section__title-wrapper text-center mb-55\">\r\n                <div className=\"section__title mb-10\">\r\n                  <h2>Trending Products</h2>\r\n                </div>\r\n                <div className=\"section__sub-title\">\r\n                  <p>Mirum est notare quam littera gothica quam nunc putamus parum claram!</p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div className=\"row\">\r\n            {trendingProducts.map((product, index) => (\r\n              <div key={index} className=\"col-xl-3 col-lg-3 col-md-6 col-sm-6\">\r\n                <div className=\"product__wrapper mb-60\">\r\n                  <div className=\"product__thumb\">\r\n                    <Link href={`/product-details/${product.id}`}>\r\n                      <a className=\"w-img\">\r\n                        <img src={product.img} alt=\"product-img\" />\r\n                        {product.thumb_img &&\r\n                          <img className=\"product__thumb-2\" src={product.thumb_img} alt=\"product-img\" />\r\n                        }\r\n                      </a>\r\n                    </Link>\r\n                    <div className=\"product__action transition-3\">\r\n                      <button onClick={() => dispatch(add_to_wishlist(product))} href=\"#\" data-bs-toggle=\"tooltip\" data-bs-placement=\"top\" title=\"Add to Wishlist\">\r\n                        <i className=\"fal fa-heart\"></i>\r\n                      </button>\r\n                      <Link href={`/product-details/${product.id}`}>\r\n                        <a data-bs-toggle=\"tooltip\" data-bs-placement=\"top\" title=\"Details\">\r\n                          <i className=\"fal fa-link\"></i>\r\n                        </a>\r\n                      </Link>\r\n                      {/* <!-- Button trigger modal --> */}\r\n                      <a onClick={() => dispatch(single_product(product.id))} href=\"#\" data-bs-toggle=\"modal\" data-bs-target=\"#productModalId\">\r\n                        <i className=\"fal fa-search\"></i>\r\n                      </a>\r\n                    </div>\r\n\r\n                    {product.product__sale && <div className=\"product__sale\">\r\n                      {product.product__sale.map((item, index) => (\r\n                        <span key={index} className={`${item === 'new' ? 'new' : 'percent'}`}>\r\n                          {item}\r\n                        </span>\r\n                      ))}\r\n                    </div>}\r\n\r\n                  </div>\r\n                  <div className=\"product__content p-relative\">\r\n                    <div className=\"product__content-inner\">\r\n                      <h4>\r\n                        <Link href={`/product-details/${product.id}`}>\r\n                          <a>{product.title}</a>\r\n                        </Link>\r\n                      </h4>\r\n                      <div className=\"product__price transition-3\">\r\n                        <span>${product.price}</span>\r\n                        {product.old_price && <span className=\"old-price\">${product.old_price}</span>}\r\n                      </div>\r\n                    </div>\r\n                    <div className=\"add-cart p-absolute transition-3\">\r\n                      <button onClick={() => dispatch(cart_product(product))}>+ Add to Cart</button>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            ))}\r\n\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n\r\n    </>\r\n  )\r\n}","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\product\\product-grid.jsx",["682","683"],[],"import { useEffect, useState } from 'react';\r\nimport ReactPaginate from 'react-paginate';\r\nimport { useDispatch, useSelector } from 'react-redux';\r\nimport Link from 'next/link';\r\n\r\nimport { add_force_page, add_item_offset, single_product } from '../../../redux/features/product-slice';\r\nimport { add_to_wishlist } from '../../../redux/features/wishlist-slice';\r\nimport { cart_product } from '../../../redux/features/cart-slice';\r\nimport Pagination from '../pagination';\r\n\r\nfunction ProductGrid({ itemsPerPage,col = \"col-xl-4 col-lg-4 col-md-6 col-sm-6 custom-col-10\",items,setShowing}){\r\n  const { forcePage, item_offset } = useSelector(state => state.products);\r\n  const dispatch = useDispatch();\r\n  const [currentItems, setCurrentItems] = useState(null);\r\n  const [pageCount, setPageCount] = useState(0);\r\n  const [itemOffset, setItemOffset] = useState(0);\r\n\r\n  useEffect(() => {\r\n    const endOffset = itemOffset + itemsPerPage;\r\n    setCurrentItems(items?.slice(itemOffset, endOffset));\r\n    setPageCount(Math.ceil(items.length / itemsPerPage));\r\n  }, [itemOffset, itemsPerPage, items]);\r\n\r\n  useEffect(() => {\r\n    if (currentItems && setShowing) {\r\n      setShowing(currentItems.length)\r\n    }\r\n  }, [currentItems, setShowing])\r\n\r\n  useEffect(() => {\r\n    dispatch(add_item_offset(itemOffset));\r\n  }, [dispatch, itemOffset]);\r\n\r\n  useEffect(() => {\r\n    setItemOffset(item_offset);\r\n  }, [item_offset]);\r\n\r\n  const handlePageClick = (event) => {\r\n    const newOffset = (event.selected * itemsPerPage) % items.length;\r\n    setItemOffset(newOffset);\r\n    dispatch(add_force_page(event.selected));\r\n  };\r\n\r\n  return (\r\n    <>\r\n      {currentItems && currentItems.map((product, index) => (\r\n        <div key={index} className={col}>\r\n          <div className=\"product__wrapper mb-60\">\r\n            <div className=\"product__thumb\">\r\n              <Link href={`/product-details/${product.id}`}>\r\n                <a className=\"w-img\">\r\n                  <img src={product.img} alt=\"product-img\" />\r\n                  {product.thumb_img &&\r\n                    <img className=\"product__thumb-2\" src={product.thumb_img} alt=\"product-img\" />\r\n                  }\r\n                </a>\r\n              </Link>\r\n              <div className=\"product__action transition-3\">\r\n                <button onClick={() => dispatch(add_to_wishlist(product))} data-bs-toggle=\"tooltip\" data-bs-placement=\"top\" title=\"Add to Wishlist\">\r\n                  <i className=\"fal fa-heart\"></i>\r\n                </button>\r\n                <Link href={`/product-details/${product.id}`}>\r\n                  <a data-bs-toggle=\"tooltip\" data-bs-placement=\"top\" title=\"Details\">\r\n                    <i className=\"fal fa-link\"></i>\r\n                  </a>\r\n                </Link>\r\n                {/* <!-- Button trigger modal --> */}\r\n                <a onClick={() => dispatch(single_product(product.id))} href=\"#\" data-bs-toggle=\"modal\" \r\n                data-bs-target=\"#productModalId\">\r\n                  <i className=\"fal fa-search\"></i>\r\n                </a>\r\n              </div>\r\n\r\n              {product.product__sale && <div className=\"product__sale\">\r\n                {product.product__sale.map((item, index) => (\r\n                  <span key={index} className={`${item === 'new' ? 'new' : 'percent'}`}>\r\n                    {item}\r\n                  </span>\r\n                ))}\r\n              </div>}\r\n\r\n            </div>\r\n            <div className=\"product__content p-relative\">\r\n              <div className=\"product__content-inner\">\r\n                <h4>\r\n                  <Link href={`/product-details/${product.id}`}>\r\n                    <a>{product.title}</a>\r\n                  </Link>\r\n                </h4>\r\n                <div className=\"product__price transition-3\">\r\n                  <span>${product.price}</span>\r\n                  {product.old_price && <span className=\"old-price\">${product.old_price}</span>}\r\n                </div>\r\n              </div>\r\n              <div className=\"add-cart p-absolute transition-3\">\r\n                <button onClick={() => dispatch(cart_product(product))}>+ Add to Cart</button>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      ))}\r\n\r\n      <div className=\"row mt-35\">\r\n        <div className=\"col-xl-12\">\r\n          <div className=\"shop-pagination-wrapper d-md-flex justify-content-between align-items-center\">\r\n            <div className=\"basic-pagination\">\r\n              <Pagination handlePageClick={handlePageClick} pageCount={pageCount} focusPage={forcePage} />\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n    </>\r\n  );\r\n}\r\n\r\n\r\nexport default ProductGrid;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\product\\product-list.jsx",["684","685"],[],"import Link from 'next/link';\r\nimport { useEffect, useState } from 'react';\r\nimport ReactPaginate from 'react-paginate';\r\nimport { useDispatch, useSelector } from 'react-redux';\r\n\r\nimport { cart_product } from '../../../redux/features/cart-slice';\r\nimport { add_force_page, add_item_offset, single_product } from '../../../redux/features/product-slice';\r\nimport { add_to_wishlist } from '../../../redux/features/wishlist-slice';\r\nimport Pagination from '../pagination';\r\n\r\nfunction ProductList({ itemsPerPage, items,setShowing }) {\r\n  const { forcePage, item_offset } = useSelector(state => state.products);\r\n  const dispatch = useDispatch();\r\n  const [currentItems, setCurrentItems] = useState(null);\r\n  const [pageCount, setPageCount] = useState(0);\r\n  const [itemOffset, setItemOffset] = useState(0);\r\n\r\n  useEffect(() => {\r\n    const endOffset = itemOffset + itemsPerPage;\r\n    setCurrentItems(items.slice(itemOffset, endOffset));\r\n    setPageCount(Math.ceil(items.length / itemsPerPage));\r\n  }, [itemOffset, itemsPerPage, items]);\r\n\r\n  useEffect(() => {\r\n    if (currentItems && setShowing) {\r\n      setShowing(currentItems.length)\r\n    }\r\n  }, [currentItems, setShowing])\r\n\r\n  useEffect(() => {\r\n    dispatch(add_item_offset(itemOffset));\r\n  }, [dispatch, itemOffset]);\r\n\r\n  useEffect(() => {\r\n    setItemOffset(item_offset);\r\n  }, [item_offset]);\r\n\r\n  const handlePageClick = (event) => {\r\n    const newOffset = (event.selected * itemsPerPage) % items.length;\r\n    setItemOffset(newOffset);\r\n    dispatch(add_force_page(event.selected));\r\n  };\r\n\r\n  return (\r\n    <>\r\n      {currentItems && currentItems.map((product, index) => (\r\n        <div key={index} className=\"product__wrapper mb-40\">\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-4 col-lg-4\">\r\n              <div className=\"product__thumb list\">\r\n                <Link href={`/product-details/${product.id}`}>\r\n                  <a className=\"w-img\">\r\n                    <img src={product.img} alt=\"product-img\" />\r\n                    {product.thumb_img && <img className=\"product__thumb-2\" src={product.thumb_img} alt=\"product-img\" />}\r\n                  </a>\r\n                </Link>\r\n                {product.product__sale && <div className=\"product__sale\">\r\n                  {product.product__sale.map((item, index) => (\r\n                    <span key={index} className={`${item === 'new' ? 'new' : 'percent'}`}>\r\n                      {item}\r\n                    </span>\r\n                  ))}\r\n                </div>}\r\n              </div>\r\n            </div>\r\n            <div className=\"col-xl-8 col-lg-8\">\r\n              <div className=\"product__content p-relative\">\r\n                <div className=\"product__content-inner list\">\r\n                  <h4>\r\n                    <Link href={`/product-details/${product.id}`}>\r\n                      <a>{product.title}</a>\r\n                    </Link>\r\n                  </h4>\r\n                  <div className=\"product__price-2 mb-10\">\r\n                    <span>${product.price}</span>\r\n                    {product?.old_price && <span className=\"old-price\">${product.old_price}</span>}\r\n                  </div>\r\n                  <p>Typi non habent claritatem insitam, est usus legentis in iis qui facit eorum claritatem. Investigationes demonstraverunt lectores legere me lius quod ii legunt saepius. Claritas est etiam processus.</p>\r\n                  <div className=\"product__list mb-30\">\r\n                    <ul>\r\n                      <li><span>Light green crewneck sweatshirt.</span></li>\r\n                      <li><span>Hand pockets.</span></li>\r\n                      <li><span>Relaxed fit.</span></li>\r\n                    </ul>\r\n                  </div>\r\n                </div>\r\n                <div className=\"add-cart-list d-sm-flex align-items-center\">\r\n                  <button onClick={() => dispatch(cart_product(product))} href=\"#\" className=\"add-cart-btn mr-10\">\r\n                    + Add to Cart</button>\r\n                  <div className=\"product__action-2 transition-3 mr-20\">\r\n                    <button onClick={() => dispatch(add_to_wishlist(product))}\r\n                    data-bs-toggle=\"tooltip\" data-placement=\"top\" title=\"Add to Wishlist\">\r\n                      <i className=\"fal fa-heart\"></i>\r\n                    </button>\r\n                    <Link href={`/product-details/${product.id}`}>\r\n                      <a data-bs-toggle=\"tooltip\" data-bs-placement=\"top\" title=\"Details\">\r\n                        <i className=\"fal fa-link\"></i>\r\n                      </a>\r\n                    </Link>\r\n                    {/* <!-- Button trigger modal --> */}\r\n                    <a onClick={() => dispatch(single_product(product.id))} href=\"#\" data-bs-toggle=\"modal\"\r\n                      data-bs-target=\"#productModalId\">\r\n                      <i className=\"fal fa-search\"></i>\r\n                    </a>\r\n\r\n                  </div>\r\n                </div>\r\n                {/* <!-- shop modal start --> */}\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      ))}\r\n\r\n      <div className=\"row mt-35\">\r\n        <div className=\"col-xl-12\">\r\n          <div className=\"shop-pagination-wrapper d-md-flex justify-content-between align-items-center\">\r\n            <div className=\"basic-pagination\">\r\n              <Pagination handlePageClick={handlePageClick} pageCount={pageCount} />\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </>\r\n  );\r\n}\r\n\r\n\r\nexport default ProductList;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\product\\product-offer.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\product\\sale-off.jsx",["686","687"],[],"import Link from 'next/link';\r\nimport { useDispatch, useSelector } from 'react-redux';\r\nimport Slider from \"react-slick\";\r\n\r\nimport { cart_product } from '../../../redux/features/cart-slice';\r\nimport { selectProducts, single_product } from '../../../redux/features/product-slice';\r\nimport { add_to_wishlist } from '../../../redux/features/wishlist-slice';\r\nimport ProductModal from '../modal/product-modal';\r\n\r\n// slider setting\r\nconst settings = {\r\n  autoplay: true,\r\n  autoplaySpeed: 10000,\r\n  arrows: false,\r\n  infinite: true,\r\n  slidesToShow: 5,\r\n  slidesToScroll: 1,\r\n  responsive: [\r\n    {\r\n      breakpoint: 1200,\r\n      settings: {\r\n        slidesToShow: 4,\r\n      }\r\n    },\r\n    {\r\n      breakpoint: 992,\r\n      settings: {\r\n        slidesToShow: 3,\r\n      }\r\n    },\r\n    {\r\n      breakpoint: 767,\r\n      settings: {\r\n        slidesToShow: 2,\r\n      }\r\n    },\r\n    {\r\n      breakpoint: 576,\r\n      settings: {\r\n        slidesToShow: 1,\r\n      }\r\n    },\r\n  ]\r\n};\r\n\r\nconst SaleOff = () => {\r\n  const products = useSelector(selectProducts);\r\n  const dispatch = useDispatch();\r\n  const saleOffProduct = products.map(item => item.product)\r\n  .flat()\r\n  .filter(prd => prd.product__sale);\r\n\r\n  return (\r\n    <>\r\n      <section className=\"sale__area pb-100\">\r\n        <div className=\"container\">\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-12\">\r\n              <div className=\"section__title-wrapper text-center mb-55\">\r\n                <div className=\"section__title mb-10\">\r\n                  <h2>Sale Off</h2>\r\n                </div>\r\n                <div className=\"section__sub-title\">\r\n                  <p>Mirum est notare quam littera gothica quam nunc putamus parum claram!</p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-12\">\r\n              <div className=\"sale__area-slider\">\r\n                <Slider {...settings}>\r\n                  {\r\n                    saleOffProduct.slice(0, 6).map((item, index) => {\r\n                      return <div key={index} className=\"sale__item\">\r\n                        <div className=\"product__wrapper mb-60\">\r\n                          <div className=\"product__thumb\">\r\n                            <Link href={`/product-details/${item.id}`}>\r\n                              <a className=\"w-img\">\r\n                                <img src={item.img} alt=\"product-img\" />\r\n                                <img className=\"product__thumb-2\" src={item.thumb_img} alt=\"product-img\" />\r\n                              </a>\r\n                            </Link>\r\n                            <div className=\"product__action transition-3\">\r\n                              <button onClick={() => dispatch(add_to_wishlist(item))} data-bs-toggle=\"tooltip\" data-bs-placement=\"top\" title=\"Add to Wishlist\">\r\n                                <i className=\"fal fa-heart\"></i>\r\n                              </button>\r\n                              <Link href={`/product-details/${item.id}`}>\r\n                                <a data-bs-toggle=\"tooltip\" data-bs-placement=\"top\" title=\"Details\">\r\n                                  <i className=\"fal fa-link\"></i>\r\n                                </a>\r\n                              </Link>\r\n                              {/* <!-- Button trigger modal --> */}\r\n                              <a onClick={() => dispatch(single_product(item.id))} href=\"#\"\r\n                                data-bs-toggle=\"modal\" data-bs-target=\"#productModalId\">\r\n                                <i className=\"fal fa-search\"></i>\r\n                              </a>\r\n\r\n                            </div>\r\n                            {item.product__sale && <div className=\"product__sale\">\r\n                              {item.product__sale.map((item, index) => (\r\n                                <span key={index} className={`${item === 'new' ? 'new' : 'percent'}`}>\r\n                                  {item}\r\n                                </span>\r\n                              ))}\r\n                            </div>}\r\n                          </div>\r\n                          <div className=\"product__content p-relative\">\r\n                            <div className=\"product__content-inner\">\r\n                              <h4>\r\n                                <Link href={`/product-details/${item.id}`}>\r\n                                  <a>{item.title}</a>\r\n                                </Link>\r\n                              </h4>\r\n                              <div className=\"product__price transition-3\">\r\n                                <span>${item.price}.00</span>\r\n                                <span className=\"old-price\">${item.old_price}.00</span>\r\n                              </div>\r\n                            </div>\r\n                            <div className=\"add-cart p-absolute transition-3\">\r\n                              <button onClick={() => dispatch(cart_product(item))}>+ Add to Cart</button>\r\n                            </div>\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    })\r\n                  }\r\n\r\n                </Slider>\r\n\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n      {/* product modal start */}\r\n      <ProductModal />\r\n      {/* product modal end */}\r\n\r\n    </>\r\n  );\r\n};\r\n\r\nexport default SaleOff;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\product\\shop-product.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\product\\shop-sidebar.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\product\\single-sm-product.jsx",["688"],[],"import Link from 'next/link';\r\nimport { useDispatch } from 'react-redux';\r\n\r\nimport { cart_product } from '../../../redux/features/cart-slice';\r\n\r\nconst SingleSmProduct = ({ product }) => {\r\n  const dispatch = useDispatch();\r\n  return (\r\n    <>\r\n      <div className=\"features__product-wrapper d-flex mb-20\">\r\n        <div className=\"features__product-thumb mr-15\">\r\n          <Link href={`/product-details/${product.id}`}>\r\n            <a>\r\n              <img src={product.img} alt=\"pro-sm-1\" />\r\n            </a>\r\n          </Link>\r\n        </div>\r\n        <div className=\"features__product-content\">\r\n          <h5>\r\n            <Link href={`/product-details/${product.id}`}>\r\n              <a>{product.title}</a>\r\n            </Link>\r\n          </h5>\r\n          <div className=\"price\">\r\n            <span>${product.price}</span>\r\n            <span className=\"price-old\">${product.old_price}</span>\r\n            <div className=\"add-cart p-absolute transition-3\">\r\n              <button onClick={() => dispatch(cart_product(product))}>+ Add to Cart</button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default SingleSmProduct;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\product\\trending-prd-2.jsx",["689","690","691","692","693","694"],[],"import Link from \"next/link\";\r\nimport { useSelector, useDispatch } from \"react-redux\";\r\nimport Slider from \"react-slick\";\r\nimport { cart_product } from \"../../../redux/features/cart-slice\";\r\nimport { selectProducts, single_product } from \"../../../redux/features/product-slice\";\r\nimport { add_to_wishlist } from \"../../../redux/features/wishlist-slice\";\r\nimport ProductModal from \"../modal/product-modal\";\r\n\r\n\r\n// slick setting\r\nconst settings = {\r\n  autoplay: true,\r\n  autoplaySpeed: 10000,\r\n  infinite: true,\r\n  arrows: false,\r\n  slidesToShow: 2,\r\n  slidesToScroll: 1,\r\n  responsive: [\r\n    {\r\n      breakpoint: 992,\r\n      settings: {\r\n        slidesToShow: 3,\r\n      }\r\n    },\r\n    {\r\n      breakpoint: 576,\r\n      settings: {\r\n        slidesToShow: 1,\r\n      }\r\n    },\r\n  ]\r\n};\r\n\r\n\r\nconst Products = () => {\r\n  const products = useSelector(selectProducts);\r\n  const products_1 = products.map(item => item.product).flat().slice(0, 3);\r\n  const products_2 = products.map(item => item.product).flat().slice(3, 6);\r\n  const big_2_product = products.map(item => item.product).flat().find(item => item.big_2);\r\n  const big_3_product = products.map(item => item.product).flat().find(item => item.big_3);\r\n  const dispatch = useDispatch();\r\n  return (\r\n    <>\r\n      <section className=\"product__area pt-60 pb-65\">\r\n        <div className=\"container\">\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-12\">\r\n              <div className=\"section__title-wrapper text-center mb-55\">\r\n                <div className=\"section__title mb-10\">\r\n                  <h2>Trending Products</h2>\r\n                </div>\r\n                <div className=\"section__sub-title\">\r\n                  <p>Mirum est notare quam littera gothica quam nunc putamus parum claram!</p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div className=\"container\">\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-6 col-lg-6\">\r\n              <div className=\"product__slider-3 owl-carousel\">\r\n                <Slider {...settings}>\r\n                  {\r\n                    products_1.map((item, index) => {\r\n                      return <div key={index}>\r\n                        <div className=\"product__item\">\r\n\r\n                          <div key={index} className=\"product__wrapper mb-60\">\r\n                            <div className=\"product__thumb\">\r\n                              <Link href={`/product-details/${item.id}`}>\r\n                                <a className=\"w-img\">\r\n                                  <img src={item.img} alt=\"product-img\" />\r\n                                  {item.thumb_img &&\r\n                                    <img className=\"product__thumb-2\" src={item.thumb_img} alt=\"product-img\" />\r\n                                  }\r\n                                </a>\r\n                              </Link>\r\n                              <div className=\"product__action transition-3\">\r\n                                <button onClick={() => dispatch(add_to_wishlist(item))} \r\n                                data-bs-toggle=\"tooltip\" data-bs-placement=\"top\" title=\"Add to Wishlist\">\r\n                                  <i className=\"fal fa-heart\"></i>\r\n                                </button>\r\n                                <Link href={`/product-details/${item.id}`}>\r\n                                  <a data-bs-toggle=\"tooltip\" data-bs-placement=\"top\" title=\"Details\">\r\n                                    <i className=\"fal fa-link\"></i>\r\n                                  </a>\r\n                                </Link>\r\n                                {/* <!-- Button trigger modal --> */}\r\n                                <a onClick={() => dispatch(single_product(item.id))} href=\"#\" data-bs-toggle=\"modal\" data-bs-target=\"#productModalId\">\r\n                                  <i className=\"fal fa-search\"></i>\r\n                                </a>\r\n                              </div>\r\n\r\n                              {item.product__sale && <div className=\"product__sale\">\r\n                                {item.product__sale.map((item, index) => (\r\n                                  <span key={index} className={`${item === 'new' ? 'new' : 'percent'}`}>\r\n                                    {item}\r\n                                  </span>\r\n                                ))}\r\n                              </div>}\r\n\r\n                            </div>\r\n                            <div className=\"product__content p-relative\">\r\n                              <div className=\"product__content-inner\">\r\n                                <h4>\r\n                                  <Link href={`/product-details/${item.id}`}>\r\n                                    <a>{item.title}</a>\r\n                                  </Link>\r\n                                </h4>\r\n                                <div className=\"product__price transition-3\">\r\n                                  <span>${item.price}.00</span>\r\n                                  <span className=\"old-price\">${item.old_price}.00</span>\r\n                                </div>\r\n                              </div>\r\n                              <div className=\"add-cart p-absolute transition-3\">\r\n                                <button onClick={() => dispatch(cart_product(item))}>+ Add to Cart</button>\r\n                              </div>\r\n                            </div>\r\n                          </div>\r\n\r\n                        </div>\r\n                      </div>\r\n                    })\r\n                  }\r\n\r\n                </Slider>\r\n\r\n              </div>\r\n              <div className=\"product__banner  mb-30\">\r\n                <Link href={`/product-details/${big_3_product.id}`}>\r\n                  <a className=\"w-img\">\r\n                    <img src={big_3_product.img} alt=\"\" />\r\n                  </a>\r\n                </Link>\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"col-xl-6 col-lg-6\">\r\n              <div className=\"product__banner w-img pb-25 mb-30\">\r\n                <Link href={`/product-details/${big_2_product.id}`}>\r\n                  <a className=\"w-img\">\r\n                    <img src={big_2_product.img} alt=\"\" />\r\n                  </a>\r\n                </Link>\r\n              </div>\r\n              <div className=\"product__slider-3 owl-carousel\">\r\n                <Slider {...settings}>\r\n                  {\r\n                    products_2.map((item, index) => {\r\n                      return <div key={index}>\r\n                        <div className=\"product__item\">\r\n                          <div key={index} className=\"product__wrapper mb-60\">\r\n                            <div className=\"product__thumb\">\r\n                              <Link href={`/product-details/${item.id}`}>\r\n                                <a className=\"w-img\">\r\n                                  <img src={item.img} alt=\"product-img\" />\r\n                                  <img className=\"product__thumb-2\" src={item.thumb_img} alt=\"product-img\" />\r\n                                </a>\r\n                              </Link>\r\n                              <div className=\"product__action transition-3\">\r\n                                <button onClick={() => dispatch(add_to_wishlist(item))}\r\n                                 data-bs-toggle=\"tooltip\" data-bs-placement=\"top\" title=\"Add to Wishlist\">\r\n                                  <i className=\"fal fa-heart\"></i>\r\n                                </button>\r\n                                <Link href={`/product-details/${item.id}`}>\r\n                                  <a data-bs-toggle=\"tooltip\" data-bs-placement=\"top\" title=\"Details\">\r\n                                    <i className=\"fal fa-link\"></i>\r\n                                  </a>\r\n                                </Link>\r\n                                {/* <!-- Button trigger modal --> */}\r\n                                <a onClick={() => dispatch(single_product(item.id))} href=\"#\" data-bs-toggle=\"modal\" data-bs-target=\"#productModalId\">\r\n                                  <i className=\"fal fa-search\"></i>\r\n                                </a>\r\n                              </div>\r\n\r\n                              {item.product__sale && <div className=\"product__sale\">\r\n                                {item.product__sale.map((item, index) => (\r\n                                  <span key={index} className={`${item === 'new' ? 'new' : 'percent'}`}>\r\n                                    {item}\r\n                                  </span>\r\n                                ))}\r\n                              </div>}\r\n\r\n                            </div>\r\n                            <div className=\"product__content p-relative\">\r\n                              <div className=\"product__content-inner\">\r\n                                <h4>\r\n                                  <Link href={`/product-details/${item.id}`}>\r\n                                    <a>{item.title}</a>\r\n                                  </Link>\r\n                                </h4>\r\n                                <div className=\"product__price transition-3\">\r\n                                  <span>${item.price}.00</span>\r\n                                  <span className=\"old-price\">${item.old_price}.00</span>\r\n                                </div>\r\n                              </div>\r\n                              <div className=\"add-cart p-absolute transition-3\">\r\n                                <button onClick={() => dispatch(cart_product(item))}>+ Add to Cart</button>\r\n                              </div>\r\n                            </div>\r\n                          </div>\r\n\r\n\r\n                        </div>\r\n                      </div>\r\n                    })\r\n                  }\r\n\r\n                </Slider>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n\r\n      {/* product modal start */}\r\n      <ProductModal />\r\n      {/* product modal end */}\r\n\r\n    </>\r\n  );\r\n};\r\n\r\nexport default Products;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\common\\product\\trending-products.jsx",["695","696"],[],"import Slider from \"react-slick\";\r\nimport { useSelector, useDispatch } from \"react-redux\";\r\nimport Link from \"next/link\";\r\n\r\nimport ProductModal from \"../modal/product-modal\";\r\nimport { selectProducts, single_product } from \"../../../redux/features/product-slice\";\r\nimport { cart_product } from \"../../../redux/features/cart-slice\";\r\nimport { add_to_wishlist } from \"../../../redux/features/wishlist-slice\";\r\n\r\n\r\nconst Products = ({ h4, h5 }) => {\r\n  // slick setting\r\n  const settings = {\r\n    autoplay: true,\r\n    autoplaySpeed: 10000,\r\n    infinite: true,\r\n    arrows: false,\r\n    slidesToShow: h4 ? 5 : h5 ? 5 : 4,\r\n    slidesToScroll: 1,\r\n    responsive: [\r\n      {\r\n        breakpoint: 1200,\r\n        settings: {\r\n          slidesToShow: 4,\r\n        }\r\n      },\r\n      {\r\n        breakpoint: 992,\r\n        settings: {\r\n          slidesToShow: 3,\r\n        }\r\n      },\r\n      {\r\n        breakpoint: 767,\r\n        settings: {\r\n          slidesToShow: 2,\r\n        }\r\n      },\r\n      {\r\n        breakpoint: 576,\r\n        settings: {\r\n          slidesToShow: 1,\r\n        }\r\n      },\r\n    ]\r\n  };\r\n\r\n  const products = useSelector(selectProducts);\r\n  const trendingItems = products.filter(item => item.trending)\r\n  const dispatch = useDispatch();\r\n\r\n  return (\r\n    <>\r\n      <section className=\"product__area pt-60 pb-100\">\r\n        <div className={`${!h5 && 'container'} ${h4 ? 'custom-container' : ''} ${h5 ? 'container-fluid' : ''}`}>\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-12\">\r\n              <div className={`section__title-wrapper text-center mb-55 ${h4 ? 'p-relative' : ''}`}>\r\n                <div className=\"section__title mb-10\">\r\n                  <h2>Trending Products</h2>\r\n                </div>\r\n                <div className=\"section__sub-title\">\r\n                  <p>Mirum est notare quam littera gothica quam nunc putamus parum claram!</p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-12\">\r\n              <div className={`product__slider ${h4 ? 'product__slider-4' : ''}`}>\r\n                <Slider {...settings}>\r\n                  {\r\n                    trendingItems.map((item, index) => {\r\n                      return <div key={index}>\r\n                        <div className=\"product__item\">\r\n                          {\r\n                            item.product.map((product, index) => (\r\n                              <div key={index} className=\"product__wrapper mb-60\">\r\n                                <div className=\"product__thumb\">\r\n                                  <Link href={`/product-details/${product.id}`}>\r\n                                    <a className=\"w-img\">\r\n                                      <img src={product.img} alt=\"product-img\" />\r\n                                      <img className=\"product__thumb-2\" src={product.thumb_img} alt=\"product-img\" />\r\n                                    </a>\r\n                                  </Link>\r\n                                  <div className=\"product__action transition-3\">\r\n                                    <button onClick={() => dispatch(add_to_wishlist(product))}\r\n                                      data-bs-toggle=\"tooltip\" data-bs-placement=\"top\" title=\"Add to Wishlist\">\r\n                                      <i className=\"fal fa-heart\"></i>\r\n                                    </button>\r\n                                    <Link href={`/product-details/${product.id}`}>\r\n                                      <a data-bs-toggle=\"tooltip\" data-bs-placement=\"top\" title=\"Details\">\r\n                                        <i className=\"fal fa-link\"></i>\r\n                                      </a>\r\n                                    </Link>\r\n                                    {/* <!-- Button trigger modal --> */}\r\n                                    <a onClick={() => dispatch(single_product(product.id))} href=\"#\" data-bs-toggle=\"modal\" data-bs-target=\"#productModalId\">\r\n                                      <i className=\"fal fa-search\"></i>\r\n                                    </a>\r\n                                  </div>\r\n\r\n                                  {product.product__sale && <div className=\"product__sale\">\r\n                                    {product.product__sale.map((item, index) => (\r\n                                      <span key={index} className={`${item === 'new' ? 'new' : 'percent'}`}>\r\n                                        {item}\r\n                                      </span>\r\n                                    ))}\r\n                                  </div>}\r\n\r\n                                </div>\r\n                                <div className=\"product__content p-relative\">\r\n                                  <div className=\"product__content-inner\">\r\n                                    <h4>\r\n                                      <Link href={`/product-details/${product.id}`}>\r\n                                        <a>{product.title}</a>\r\n                                      </Link>\r\n                                    </h4>\r\n                                    <div className=\"product__price transition-3\">\r\n                                      <span>${product.price}.00</span>\r\n                                      <span className=\"old-price\">${product.old_price}.00</span>\r\n                                    </div>\r\n                                  </div>\r\n                                  <div className=\"add-cart p-absolute transition-3\">\r\n                                    <button onClick={() => dispatch(cart_product(product))}>+ Add to Cart</button>\r\n                                  </div>\r\n                                </div>\r\n                              </div>\r\n                            ))\r\n                          }\r\n\r\n                        </div>\r\n                      </div>\r\n                    })\r\n                  }\r\n\r\n                </Slider>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-12\">\r\n              <div className=\"product__load-btn text-center mt-25\">\r\n                <Link href=\"/shop\">\r\n                  <a className=\"os-btn os-btn-3\">See More</a>\r\n                </Link>\r\n  