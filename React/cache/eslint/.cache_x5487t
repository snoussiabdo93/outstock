.length === 0 &&\r\n                <div className='text-center'>\r\n                  <h3>No wishlist product</h3>\r\n                </div>\r\n              }\r\n              {wishlist.length > 0 && <form onSubmit={handleSubmit}>\r\n                <div className=\"table-content table-responsive\">\r\n                  <table className=\"table\">\r\n                    <thead>\r\n                      <tr>\r\n                        <th className=\"product-thumbnail\">Images</th>\r\n                        <th className=\"cart-product-name\">Product</th>\r\n                        <th className=\"product-price\">Unit Price</th>\r\n                        <th className=\"product-quantity\">Quantity</th>\r\n                        <th className=\"product-subtotal\">Total</th>\r\n                        <th className=\"product-remove\">Remove</th>\r\n                      </tr>\r\n                    </thead>\r\n                    <tbody>\r\n                      {wishlist.map((product, index) => (\r\n                        <tr key={index}>\r\n                          <td className=\"product-thumbnail\">\r\n                            <Link href={`/product-details/${product.id}`}>\r\n                              <a>\r\n                                <img src={product.img} alt=\"\" />\r\n                              </a>\r\n                            </Link>\r\n                          </td>\r\n                          <td className=\"product-name\">\r\n                            <Link href={`/product-details/${product.id}`}>\r\n                              <a>{product.title}</a>\r\n                            </Link>\r\n                          </td>\r\n                          <td className=\"product-price\"><span className=\"amount\">${product.price}</span></td>\r\n                          <td className=\"product-quantity\">\r\n                            <button onClick={() => dispatch(cart_product(product))} className=\"os-btn os-btn-black\" type=\"submit\">Add TO Cart</button>\r\n                          </td>\r\n                          <td className=\"product-subtotal\">\r\n                            <span className=\"amount\">${product.price}</span>\r\n                          </td>\r\n                          <td className=\"product-remove\"><button\r\n                            onClick={() => dispatch(remove_wishlist_product(product))}><i className=\"fa fa-times\"></i>\r\n                          </button></td>\r\n                        </tr>\r\n                      ))}\r\n\r\n                    </tbody>\r\n                  </table>\r\n                </div>\r\n              </form>}\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default WishlistArea;",{"ruleId":"711","severity":1,"message":"712","line":50,"column":19,"nodeType":"713","endLine":50,"endColumn":52},{"ruleId":"711","severity":1,"message":"712","line":22,"column":29,"nodeType":"713","endLine":22,"endColumn":62},{"ruleId":"711","severity":1,"message":"712","line":47,"column":17,"nodeType":"713","endLine":47,"endColumn":46},{"ruleId":"711","severity":1,"message":"712","line":64,"column":19,"nodeType":"713","endLine":64,"endColumn":76},{"ruleId":"711","severity":1,"message":"712","line":110,"column":31,"nodeType":"713","endLine":110,"endColumn":64},{"ruleId":"711","severity":1,"message":"712","line":141,"column":29,"nodeType":"713","endLine":141,"endColumn":60},{"ruleId":"711","severity":1,"message":"712","line":45,"column":33,"nodeType":"713","endLine":45,"endColumn":62},{"ruleId":"711","severity":1,"message":"712","line":11,"column":15,"nodeType":"713","endLine":11,"endColumn":46},{"ruleId":"711","severity":1,"message":"712","line":18,"column":27,"nodeType":"713","endLine":18,"endColumn":64},{"ruleId":"711","severity":1,"message":"712","line":60,"column":31,"nodeType":"713","endLine":60,"endColumn":64},{"ruleId":"711","severity":1,"message":"712","line":30,"co