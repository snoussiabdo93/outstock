k\\components\\home\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\login\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\login\\login-area.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\preloader.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\register\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\register\\register-area.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\seo.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\shop\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\shop-3-col\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\shop-3-col\\shop-3-col-area.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\shop-4-col\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\shop-4-col\\shop-4-col-area.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\shop-right\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\wishlist\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\wishlist\\wishlist-area.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\pages\\about.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\about\\About.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\about\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog\\blog-area.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-2-col\\blog-2-col.jsx",["645"],[],"import Link from \"next/link\";\r\nimport { useEffect, useState } from \"react\";\r\nimport ReactPaginate from \"react-paginate\";\r\nimport { blogs } from \"../../data\";\r\n\r\nconst items = blogs.slice(0, 8);\r\n\r\nconst BlogTwoCol = () => {\r\n  return (\r\n    <>\r\n      <section className=\"blog__area pt-100 pb-100\">\r\n        <div className=\"container\">\r\n          <div className=\"row\">\r\n            <BlogItems itemsPerPage={6} items={items} />\r\n          </div>\r\n        </div>\r\n      </section>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default BlogTwoCol;\r\n\r\n\r\nexport const BlogItems = ({ itemsPerPage, items, colThree }) => {\r\n  const [currentItems, setCurrentItems] = useState(null);\r\n  const [pageCount, setPageCount] = useState(0);\r\n  const [itemOffset, setItemOffset] = useState(0);\r\n\r\n  useEffect(() => {\r\n    const endOffset = itemOffset + itemsPerPage;\r\n    setCurrentItems(items.slice(itemOffset, endOffset));\r\n    setPageCount(Math.ceil(items.length / itemsPerPage));\r\n  }, [itemOffset, itemsPerPage, items]);\r\n\r\n  const handlePageClick = (event) => {\r\n    const newOffset = (event.selected * itemsPerPage) % items.length;\r\n    setItemOffset(newOffset);\r\n  };\r\n\r\n  return (\r\n    <>\r\n\r\n      {currentItems && currentItems.map((item, index) => (\r\n        <div key={index} className={colThree ? 'col-xl-4 col-lg-4 col-md-6' : \"col-xl-6 col-lg-6 col-md-6\"}>\r\n          <div key={index} className=\"blog__item mb-60\">\r\n            <div className=\"blog__thumb fix\">\r\n              <Link href={`/blog-details/${item.id}`}>\r\n                <a className=\"w-img\">\r\n                  <img src={item.img} alt=\"blog\" />\r\n                </a>\r\n              </Link>\r\n            </div>\r\n            <div className=\"blog__content\">\r\n              <h4>\r\n                <Link href={`/blog-details/${item.id}`}>\r\n                  <a>{item.title}</a>\r\n                </Link>\r\n              </h4>\r\n              <div className=\"blog__meta\">\r\n                <span>By <a href=\"#\">{item.author}</a></span>\r\n                <span>/ {item.date}</span>\r\n              </div>\r\n              <p>{item.desc.substring(0, 120)}[...]</p>\r\n              <Link href={`/blog-details/${item.id}`}>\r\n                <a className=\"os-btn\">read more</a>\r\n              </Link>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      ))}\r\n\r\n\r\n      <div className=\"row \">\r\n        <div className=\"col-xl-12\">\r\n          <div className=\"mt-35 shop-pagination-wrapper d-md-flex justify-content-between align-items-center\">\r\n\r\n            <div className=\"basic-pagination\">\r\n              <ReactPaginate\r\n                nextLabel={<><i className=\"fal fa-angle-right\"></i></>}\r\n                onPageChange={handlePageClick}\r\n                pageRangeDisplayed={3}\r\n                marginPagesDisplayed={2}\r\n                pageCount={pageCount}\r\n                previousLabel={<><i className=\"fal fa-angle-left\"></i></>}\r\n                pageClassName=\"page-item\"\r\n                pageLinkClassName=\"page-link\"\r\n                previousClassName=\"page-item\"\r\n                previousLinkClassName=\"page-link\"\r\n                nextClassName=\"page-item\"\r\n                nextLinkClassName=\"page-link\"\r\n                breakLabel=\"...\"\r\n                breakClassName=\"page-item\"\r\n                breakLinkClassName=\"page-link\"\r\n                containerClassName=\"pagination\"\r\n                activeClassName=\"active\"\r\n                renderOnZeroPageCount={null}\r\n              />\r\n            </div>\r\n\r\n            <div className=\"shop__header-left\">\r\n              <div className=\"show-text bottom\">\r\n                <span>Showing 1–{currentItems?.length} of {items?.length} results</span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n    </>\r\n  )\r\n}","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-2-col\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-2-col-mas\\blog-2-col-mas.jsx",["646"],[],"import Link from \"next/link\";\r\nimport Masonry, { ResponsiveMasonry } from \"react-responsive-masonry\";\r\n\r\nimport { blogs } from '../../data';\r\n\r\nconst items = blogs.filter(blog => blog.masonry).reverse();\r\n\r\nconst BlogTwoCalMas = () => {\r\n  return (\r\n    <>\r\n      <section className=\"blog__area pt-100 pb-100\">\r\n        <div className=\"container\">\r\n          <div className=\"row\">\r\n            <ResponsiveMasonry columnsCountBreakPoints={{ 0: 1, 750: 2, }} >\r\n              <Masonry gutter=\"25px\">\r\n                {items.map((item, index) => (\r\n                  <div key={index} className=\"\">\r\n                    <div className=\"blog__item mb-60\">\r\n                      <div className=\"blog__thumb fix\">\r\n                        <Link href={`/blog-details/${item.id}`}>\r\n                          <a className=\"w-img\">\r\n                            <img src={item.img} alt=\"blog\" />\r\n                          </a>\r\n                        </Link>\r\n                      </div>\r\n                      <div className=\"blog__content\">\r\n                        <h4>\r\n                          <Link href={`/blog-details/${item.id}`}>\r\n                            <a>{item.title}</a>\r\n                          </Link>\r\n                        </h4>\r\n                        <div className=\"blog__meta\">\r\n                          <span>By <a href=\"#\">{item.author}</a></span>\r\n                          <span>/ {item.date}</span>\r\n                        </div>\r\n                        <p>{item.desc}</p>\r\n                        <Link href={`/blog-details/${item.id}`}>\r\n                          <a className=\"os-btn\">read more</a>\r\n                        </Link>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                ))}\r\n              </Masonry>\r\n            </ResponsiveMasonry>\r\n          </div>\r\n\r\n        </div>\r\n      </section>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default BlogTwoCalMas;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-2-col-mas\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-3-col\\blog-three-col.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-3-col\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-details\\blog-details-area.jsx",["647","648","649","650"],[],"import BlogSidebar from '../common/blog/blog-sidebar';\r\nimport { blogs } from '../../data';\r\nimport BlogForm from '../common/form/blog-form';\r\nimport Link from 'next/link';\r\n\r\nconst reviews = [\r\n  {\r\n    img: '/assets/img/blog/comments/avater-1.png',\r\n    name: 'Siarhei Dzenisenka',\r\n    time: '3 Months Ago',\r\n    rating: 4,\r\n  },\r\n  {\r\n    img: '/assets/img/blog/comments/avater-2.png',\r\n    name: 'Julias Roy',\r\n    time: '6 Months Ago',\r\n    rating: 4,\r\n    children: true,\r\n  },\r\n  {\r\n    img: '/assets/img/blog/comments/avater-3.png',\r\n    name: 'Arista Williamson',\r\n    time: '6 Months Ago',\r\n    rating: 4,\r\n  },\r\n]\r\n\r\nconst BlogDetailsArea = ({ item }) => {\r\n  return (\r\n    <>\r\n      <section className=\"blog__area pt-55\">\r\n        <div className=\"container\">\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-9 col-lg-8\">\r\n              <div className=\"postbox__title mb-55\">\r\n                <h1>\r\n                  <Link href={'/blog'}>\r\n                    <a>{item.title}</a>\r\n                  </Link>\r\n                </h1>\r\n                <div className=\"blog__meta\">\r\n                  <span>By <a href=\"#\">{item.author}</a></span>\r\n                  <span>/ {item.date}</span>\r\n                </div>\r\n              </div>\r\n              <div className=\"postbox__thumb w-img\">\r\n                <img src={item.img} alt=\"\" />\r\n              </div>\r\n              <div className=\"postbox__wrapper mb-70\">\r\n                <div className=\"postbox__text mt-65\">\r\n                  <p>Diga, Koma and Torus are three kitchen utensils designed for <span className=\"highlight theme\">Ommo</span>, a new design-oriented brand introduced at the Ambiente show in February 2016. <span className=\"highlight\">Minimalist approach, bright colors, stainless steel and matte plastic</span>, abstract shapes and curved lines are the defining features of these products designed to be extremely functional, user-friendly and fun.</p>\r\n                </div>\r\n                <div className=\"postbox__text\">\r\n                  <p>Diga is a two-color melamine salad bowl where vegetables can be washed, drained and served. The disk at the bottom of the bowl can be turned counterclockwise to drain water when washing vegetables and it can be turned clockwise to lock the drain and hold condiments in the bowl when serving.</p>\r\n                </div>\r\n                <article className=\"postbox format-quote mt-45 mb-50\">\r\n                  <div className=\"postbox__quote\">\r\n                    <blockquote>\r\n                      <p> <i className=\"fas fa-quote-right\"></i> Many desktop publishing packages and web page editors now use Lorem Ipsum as their default model text, and a search for lorem ipsum will uncover many web sites still in their infancy. </p>\r\n                    </blockquote>\r\n                  </div>\r\n                </article>\r\n                <div className=\"postbox__details-img w-img mb-60\">\r\n                  <img src=\"/assets/img/blog/blog-details-sm.jpg\" alt=\"\" />\r\n                </div>\r\n                <div className=\"postbox__text\">\r\n                  <p>Koma and Torus are two tea infusers, each with an original design and a concealed function. Koma has a round base and a long stainless steel-trimmed handle which offers a comfortable grip and allows.\r\n                  </p>\r\n                </div>\r\n                <div className=\"postbox__text\">\r\n                  <p>And the brushed steel cover opens and closes at the touch of a finger to easily fill and empty the infuser. The perfect way to enjoy brewing tea. Torus is donut-shaped and can      cling to any cup. It is accompanied by a case that can contain up to three different diffusers and can be used for dry storage of loose tea.\r\n                  </p>\r\n                </div>\r\n              </div>\r\n              <div className=\"postbox__share mb-95\">\r\n                <div className=\"row\">\r\n                  <div className=\"col-xl-6 col-lg-6 col-md-6\">\r\n                    <div className=\"postbox__social\">\r\n                      <span>Share to friends:</span>\r\n                      <ul>\r\n                        <li><a href=\"#\"><i className=\"fab fa-facebook-f\"></i></a></li>\r\n                        <li><a href=\"#\"><i className=\"fab fa-twitter\"></i></a></li>\r\n                        <li><a href=\"#\"><i className=\"fab fa-dribbble\"></i></a></li>\r\n                        <li><a href=\"#\"><i className=\"fas fa-share-alt\"></i></a></li>\r\n                      </ul>\r\n                    </div>\r\n                  </div>\r\n                  <div className=\"col-xl-6 col-lg-6 col-md-6\">\r\n                    <div className=\"postbox__tag f-right\">\r\n                      <span>Tags :</span>\r\n                      <a href=\"#\">Furniture,</a>\r\n                      <a href=\"#\">Erentheme,</a>\r\n                      <a href=\"#\">Chair, </a>\r\n                      <a href=\"#\">Decor</a>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n              <div className=\"postbox__related-title\">\r\n                <h3>You Might Also Like</h3>\r\n              </div>\r\n              <div className=\"postbox__related-item\">\r\n                <div className=\"row\">\r\n                  {blogs.slice(0, 2).map((blog, index) => (\r\n                    <div key={index} className=\"col-xl-6 col-lg-6 col-md-6\">\r\n                      <div className=\"blog__item mb-30\">\r\n                        <div className=\"blog__thumb fix\">\r\n                          <Link href={`/blog-details/${blog.id}`}>\r\n                            <a className=\"w-img\">\r\n                              <img src={blog.img} alt=\"blog\" />\r\n                            </a>\r\n                          </Link>\r\n                        </div>\r\n                        <div className=\"blog__content\">\r\n                          <h4>\r\n                            <Link href={`/blog-details/${blog.id}`}>\r\n                              <a>{blog.title}</a>\r\n                            </Link>\r\n                          </h4>\r\n                          <div className=\"blog__meta\">\r\n                            <span>By <a href=\"#\">{blog.auhtor}</a></span>\r\n                            <span>/ {blog.date}</span>\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  ))}\r\n                </div>\r\n              </div>\r\n              <div className=\"postbox__line mt-65\"></div>\r\n              <div className=\"postbox__comments pt-90\">\r\n                <div className=\"postbox__comment-title mb-30\">\r\n                  <h3>Comments (32)</h3>\r\n                </div>\r\n                <div className=\"latest-comments mb-30\">\r\n                  <ul>\r\n                    {reviews.map((review, index) => (\r\n                      <li key={index} className={review.children ? 'children' : ''}>\r\n                        <div className=\"comments-box\">\r\n                          <div className=\"comments-avatar\">\r\n                            <img src={review.img} alt=\"\" />\r\n                          </div>\r\n                          <div className=\"comments-text\">\r\n                            <div className=\"avatar-name\">\r\n                              <h5>{review.name}</h5>\r\n                              <span> - {review.time} </span>\r\n                              <a className=\"reply\" href=\"#\">Leave Reply</a>\r\n                            </div>\r\n                            <div className=\"user-rating\">\r\n                              <ul>\r\n                                <li><a href=\"#\"><i className=\"fas fa-star\"></i></a></li>\r\n                                <li><a href=\"#\"><i className=\"fas fa-star\"></i></a></li>\r\n                                <li><a href=\"#\"><i className=\"fas fa-star\"></i></a></li>\r\n                                <li><a href=\"#\"><i className=\"fas fa-star\"></i></a></li>\r\n                                <li><a href=\"#\"><i className=\"fal fa-star\"></i></a></li>\r\n                              </ul>\r\n                            </div>\r\n                            <p>Many desktop publishing packages and web page editors now use Lorem Ipsum as their default model text, and a search for <span>“lorem ipsum”</span> will uncover many web sites still in their infancy. Various versions have evolved over the years, sometimes by accident, sometimes on purpose.</p>\r\n                          </div>\r\n                        </div>\r\n                      </li>\r\n                    ))}\r\n                  </ul>\r\n                </div>\r\n              </div>\r\n              <div className=\"postbox__line mb-95\"></div>\r\n              <div className=\"post-comments-form mb-100\">\r\n                <div className=\"post-comments-title mb-30\">\r\n                  <h3>Leave A Reply</h3>\r\n                </div>\r\n                {/* blog form start */}\r\n                <BlogForm />\r\n                {/* blog form start */}\r\n              </div>\r\n            </div>\r\n            <div className=\"col-xl-3 col-lg-4\">\r\n              <BlogSidebar />\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default BlogDetailsArea;\r\n","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-details\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-left-sidebar\\blog-left-sidebar.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-left-sidebar\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-no-sidebar\\blog-no-sidebar.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\blog-no-sidebar\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-2\\hero-slider.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-2\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-2\\products-items.jsx",["651","652","653"],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-2\\sale-off-area.jsx",["654","655"],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-3\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-3\\testimonial.jsx",["656"],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-4\\hero-slider.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-4\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-5\\hero-slider.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-5\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Deskt