blog.id}`}>\r\n                          <a className=\"btn\">\r\n                            <i className=\"fa fa-link\"></i>\r\n                          </a>\r\n                        </Link>\r\n                      </div>\r\n                      <div className=\"blog__post-content\">\r\n                        <div className=\"blog__wrapper\">\r\n                          <h5 className=\"blog__post-title\">\r\n                            <Link href={`/blog-details/${blog.id}`}>\r\n                              <a>{blog.title}</a>\r\n                            </Link>\r\n                          </h5>\r\n                          <div className=\"article-meta d-flex justify-content-center\">\r\n                            <span className=\"article-author\"><span>By</span> {blog.author}</span>\r\n                            <span> /</span>\r\n                            <span className=\"article-publish\">\r\n                              <i className=\"fa fa-calendar-o\"></i>{blog.date}\r\n                            </span>\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  ))}\r\n                </Slider>\r\n\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default Blogs;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-7\\fashion-prd.jsx",["722","723","724"],[],"import Link from 'next/link';\r\nimport React from 'react';\r\nimport { useDispatch, useSelector } from 'react-redux';\r\n\r\nimport { selectProducts, single_product } from '../../redux/features/product-slice';\r\nimport ProductModal from '../common/modal/product-modal';\r\n\r\nconst FashionProduct = () => {\r\n  const products = useSelector(selectProducts);\r\n  const fashion_products = products.map(item => item.product).flat().filter(item => item.f_prd);\r\n  return (\r\n    <>\r\n      <div className=\"product__view-area pt-60 pb-60\">\r\n        <div className=\"container custom-container-2\">\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-12\">\r\n              <div className=\"section__wrapper text-center\">\r\n                <h3 className=\"section__title-2\"><span>BESTSELLER PRODUCTS</span></h3>\r\n                <p>Eodem modo typi, qui nunc nobis videntur parum clari</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div className=\"row mt-40\">\r\n            <div className=\"col-xl-6 col-lg-6\">\r\n              <div className=\"row\">\r\n                <div className=\"col-lg-12\">\r\n                  <div className=\"row\">\r\n                    {fashion_products.slice(0, 2).map(prd => (\r\n                      <SingleFashionPrd key={prd.id} prd={prd} />\r\n                    ))}\r\n\r\n                  </div>\r\n                </div>\r\n                <div className=\"col-lg-12\">\r\n                  <FashionBigProduct prdNumber={0} />\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"col-lg-6 col-lg-6\">\r\n              <div className=\"row\">\r\n                <div className=\"col-lg-12\">\r\n                  <FashionBigProduct prdNumber={1} />\r\n                </div>\r\n                <div className=\"col-lg-12\">\r\n                  <div className=\"row\">\r\n                    {fashion_products.slice(2, 4).map(prd => (\r\n                      <SingleFashionPrd key={prd.id} prd={prd} />\r\n                    ))}\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default FashionProduct;\r\n\r\n\r\nconst SingleFashionPrd = ({ prd }) => {\r\n  const dispatch = useDispatch();\r\n  return (\r\n    <>\r\n      <div className=\"col-xl-6 col-lg-12 col-md-6\">\r\n        <div className=\"product__item mb-40\">\r\n          <div className=\"product__wrapper\">\r\n            <div className=\"product__thumb\">\r\n              <Link href={`/product-details/${prd.id}`}>\r\n                <a className=\"w-img\">\r\n                  <img src={prd.img} alt=\"product-img\" />\r\n                  <img className=\"product__thumb-2\" src={prd.thumb_img} alt=\"product-img\" />\r\n                </a>\r\n              </Link>\r\n              <div className=\"product__action-3 transition-3\">\r\n                <Link href={`/product-details/${prd.id}`}>\r\n                  <a className=\"action-btn\">\r\n                    <i className=\"fal fa-plus\"></i> Select Option</a>\r\n                </Link>\r\n\r\n                <a className=\"action-btn\" onClick={() => dispatch(single_product(prd.id))} \r\n                href=\"#\" data-bs-toggle=\"modal\" data-bs-target=\"#productModalId\">\r\n                  <i className=\"fal fa-eye\"></i>\r\n                </a>\r\n\r\n              </div>\r\n              {prd.new && <div className=\"product__sale product__sale-3\">\r\n                <span className=\"new\">new</span>\r\n              </div>}\r\n            </div>\r\n            <div className=\"product__content product__content-2 p-relative text-center\">\r\n              <div className=\"product__content-inner\">\r\n                <div className=\"rating\">\r\n                  <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                  <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                  <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                  <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                  <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                </div>\r\n                <h4>\r\n                  <Link href={`/product-details/${prd.id}`}>\r\n                    <a>{prd.title}</a>\r\n                  </Link>\r\n                </h4>\r\n                <div className=\"product__price-3\">\r\n                  <span>${prd.price}.00</span>\r\n                  {prd.old_price && <span className=\"old-price\">\r\n                    <del> ${prd.old_price}.00</del>\r\n                  </span>}\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      {/* product modal start */}\r\n      <ProductModal />\r\n      {/* product modal end */}\r\n\r\n    </>\r\n  )\r\n}\r\n\r\n\r\nconst FashionBigProduct = ({ prdNumber }) => {\r\n  const products = useSelector(state => state.products.products);\r\n  const fashion_big_prd = products.map(item => item.product).flat().filter(item => item.f_prd_big);\r\n  return (\r\n    <div className=\"product__big-image effectThree mb-40\">\r\n      <Link href={`/product-details/${fashion_big_prd[prdNumber].id}`}>\r\n        <a>\r\n          <img src={fashion_big_prd[prdNumber].img} alt=\"\" />\r\n        </a>\r\n      </Link>\r\n    </div>\r\n  )\r\n}","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-7\\feature-products.jsx",["725","726"],[],"import Link from 'next/link';\r\nimport { useDispatch, useSelector } from 'react-redux';\r\nimport Slider from 'react-slick';\r\n\r\nimport { single_product } from '../../redux/features/product-slice';\r\nimport { SampleNextArrow, SamplePrevArrow } from '../../utils/slider-arrow';\r\n\r\n// slick setting\r\nconst settings = {\r\n  autoplay: false,\r\n  autoplaySpeed: 10000,\r\n  slidesToShow: 4,\r\n  nextArrow: <SampleNextArrow />,\r\n  prevArrow: <SamplePrevArrow />,\r\n  responsive: [\r\n    {\r\n      breakpoint: 992,\r\n      settings: {\r\n        slidesToShow: 3,\r\n      }\r\n    },\r\n    {\r\n      breakpoint: 767,\r\n      settings: {\r\n        slidesToShow: 2,\r\n      }\r\n    },\r\n    {\r\n      breakpoint: 576,\r\n      settings: {\r\n        slidesToShow: 1,\r\n      }\r\n    },\r\n  ]\r\n};\r\n\r\n\r\nconst FeatureProducts = () => {\r\n  const products = useSelector(state => state.products.products);\r\n  const fashion_products = products.map(item => item.product).flat().filter(item => item.feature_prd);\r\n  const dispatch = useDispatch();\r\n  return (\r\n    <>\r\n      <div className=\"product__slider-area pt-95 pb-60\">\r\n        <div className=\"container custom-container-2\">\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-12\">\r\n              <div className=\"section__wrapper text-center\">\r\n                <h3 className=\"section__title-2\"><span>FEATURED PRODUCTS</span></h3>\r\n                <p>Claritas est etiam processus dynamicus, qui sequitur.</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div className=\"row mt-40\">\r\n            <div className=\"col-lg-12\">\r\n\r\n              <Slider className='product__slider-active slick-gap slick-carousel' {...settings}>\r\n                {\r\n                  fashion_products.map((prd, index) => {\r\n                    return <div key={index} className=\"product__slider-item\">\r\n                      <div className=\"product__item mb-40\">\r\n                        <div className=\"product__wrapper\">\r\n                          <div className=\"product__thumb\">\r\n                            <Link href={`/product-details/${prd.id}`}>\r\n                              <a className=\"w-img\">\r\n                                <img src={prd.img} alt=\"product-img\" />\r\n                                <img className=\"product__thumb-2\" src={prd.thumb_img} alt=\"product-img\" />\r\n                              </a>\r\n                            </Link>\r\n                            <div className=\"product__action-3 transition-3\">\r\n                              <Link href={`/product-details/${prd.id}`}>\r\n                                <a className=\"action-btn\">\r\n                                  <i className=\"fal fa-plus\"></i> Select Option</a>\r\n                              </Link>\r\n\r\n                              <a className=\"action-btn\" onClick={() => dispatch(single_product(prd.id))} href=\"#\"\r\n                                data-bs-toggle=\"modal\" data-bs-target=\"#productModalId\">\r\n                                <i className=\"fal fa-eye\"></i>\r\n                              </a>\r\n\r\n                            </div>\r\n                            {prd.new && <div className=\"product__sale product__sale-3\">\r\n                              <span className=\"new\">new</span>\r\n                            </div>}\r\n                          </div>\r\n                          <div className=\"product__content product__content-2 p-relative text-center\">\r\n                            <div className=\"product__content-inner\">\r\n                              <div className=\"rating\">\r\n                                <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                                <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                                <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                                <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                                <a href=\"#\"><i className=\"fal fa-star\"></i></a>\r\n                              </div>\r\n                              <h4>\r\n                                <Link href={`/product-details/${prd.id}`}>\r\n                                  <a>{prd.title}</a>\r\n                                </Link>\r\n                              </h4>\r\n                              <div className=\"product__price-3\">\r\n                                <span>${prd.price}.00</span>\r\n                                {prd.old_price && <span className=\"old-price\">\r\n                                  <del> ${prd.old_price}.00</del>\r\n                                </span>}\r\n                              </div>\r\n                            </div>\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  })\r\n                }\r\n              </Slider>\r\n\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default FeatureProducts;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-7\\hero-slider.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-7\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-7\\testimonial.jsx",["727"],[],"import Slider from \"react-slick\";\r\n\r\n\r\nconst testimonial_data = [\r\n  {\r\n    id: 1,\r\n    img: 'assets/img/testimonial/testi1.webp',\r\n    desc: 'Great theme, extended super and fast professional support. easy to use, flexible, visual composer and more functional plugins on board. Yes a real good, strong theme with structured coding. Enjoy it! friendly and super good!'\r\n  },\r\n  {\r\n    id: 2,\r\n    img: 'assets/img/testimonial/testi2.webp',\r\n    desc: 'Great theme, extended super and fast professional support. easy to use, flexible, visual composer and more functional plugins on board. Yes a real good, strong theme with structured coding. Enjoy it! friendly and super good!'\r\n  },\r\n  {\r\n    id: 3,\r\n    img: 'assets/img/testimonial/testi3.webp',\r\n    desc: 'Great theme, extended super and fast professional support. easy to use, flexible, visual composer and more functional plugins on board. Yes a real good, strong theme with structured coding. Enjoy it! friendly and super good!'\r\n  },\r\n]\r\n\r\n// slick setting\r\nconst settings = {\r\n  slidesToShow: 1,\r\n  slidesToScroll: 1,\r\n  arrows: false,\r\n  dots: true,\r\n};\r\n\r\nconst Testimonial = () => {\r\n  return (\r\n    <>\r\n      <div className=\"testimonial__area grey-bg pt-95 pb-95\">\r\n        <div className=\"container custom-container-2\">\r\n          <div className=\"row\">\r\n            <div className=\"col-lg-12\">\r\n              <div className=\"row\">\r\n                <div className=\"col-xl-12\">\r\n                  <div className=\"section__wrapper text-center mb-40\">\r\n                    <h3 className=\"section__title-2\">OUR TESTIMONIAL</h3>\r\n                    <p className=\"sub-title\">Commodo sociosqu venenatis cras dolor sagittis integer luctus sem primis eget maecenas sed urna malesuada consectetuer</p>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div className=\"row\">\r\n            <div className=\"col-lg-12\">\r\n              <div className=\"testimonial__slider-active\">\r\n                <Slider {...settings}>\r\n                  {testimonial_data.map((item) => (\r\n                    <div key={item.id} className=\"testimonail__slider-item\">\r\n                      <div className=\"testimonial__image text-center mb-50\">\r\n                        <img src={item.img} alt=\"\" />\r\n                      </div>\r\n                      <div className=\"testimonial__content\">\r\n                        <p>{item.desc}</p>\r\n                      </div>\r\n                    </div>\r\n                  ))}\r\n                </Slider>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default Testimonial;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\home-7\\video-box.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\login\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\login\\login-area.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\preloader.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\register\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\register\\register-area.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\seo.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\shop\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\shop-3-col\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\shop-3-col\\shop-3-col-area.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\shop-4-col\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\shop-4-col\\shop-4-col-area.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\shop-right\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\wishlist\\index.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\wishlist\\wishlist-area.jsx",["728"],[],"import Link from 'next/link';\r\nimport React from 'react';\r\nimport { useDispatch, useSelector } from 'react-redux';\r\nimport { cart_product } from '../../redux/features/cart-slice';\r\nimport { remove_wishlist_product, wishlistItems } from '../../redux/features/wishlist-slice';\r\n\r\nconst WishlistArea = () => {\r\n  const wishlist = useSelector(wishlistItems);\r\n  const dispatch = useDispatch();\r\n  const handleSubmit = e => e.preventDefault();\r\n  return (\r\n    <>\r\n      <section className=\"cart-area pt-100 pb-100\">\r\n        <div className=\"container\">\r\n          <div className=\"row\">\r\n            <div className=\"col-12\">\r\n              {wishlist.length === 0 &&\r\n                <div className='text-center'>\r\n                  <h3>No wishlist product</h3>\r\n                </div>\r\n              }\r\n              {wishlist.length > 0 && <form onSubmit={handleSubmit}>\r\n                <div className=\"table-content table-responsive\">\r\n                  <table className=\"table\">\r\n                    <thead>\r\n                      <tr>\r\n                        <th className=\"product-thumbnail\">Images</th>\r\n                        <th className=\"cart-product-name\">Product</th>\r\n                        <th className=\"product-price\">Unit Price</th>\r\n                        <th className=\"product-quantity\">Quantity</th>\r\n                        <th className=\"product-subtotal\">Total</th>\r\n                        <th className=\"product-remove\">Remove</th>\r\n                      </tr>\r\n                    </thead>\r\n                    <tbody>\r\n                      {wishlist.map((product, index) => (\r\n                        <tr key={index}>\r\n                          <td className=\"product-thumbnail\">\r\n                            <Link href={`/product-details/${product.id}`}>\r\n                              <a>\r\n                                <img src={product.img} alt=\"\" />\r\n                              </a>\r\n                            </Link>\r\n                          </td>\r\n                          <td className=\"product-name\">\r\n                            <Link href={`/product-details/${product.id}`}>\r\n                              <a>{product.title}</a>\r\n                            </Link>\r\n                          </td>\r\n                          <td className=\"product-price\"><span className=\"amount\">${product.price}</span></td>\r\n                          <td className=\"product-quantity\">\r\n                            <button onClick={() => dispatch(cart_product(product))} className=\"os-btn os-btn-black\" type=\"submit\">Add TO Cart</button>\r\n                          </td>\r\n                          <td className=\"product-subtotal\">\r\n                            <span className=\"amount\">${product.price}</span>\r\n                          </td>\r\n                          <td className=\"product-remove\"><button\r\n                            onClick={() => dispatch(remove_wishlist_product(product))}><i className=\"fa fa-times\"></i>\r\n                          </button></td>\r\n                        </tr>\r\n                      ))}\r\n\r\n                    </tbody>\r\n                  </table>\r\n                </div>\r\n              </form>}\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default WishlistArea;","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\pages\\about.jsx",[],[],"C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\about\\About.jsx",["729"],[],"import Image from \"next/image\";\r\nimport about from \"../../public/assets/img/bg/about.png\"\r\n\r\n\r\n\r\nconst About = () => {\r\n  return (\r\n    <>\r\n      <section className=\"contact__area pb-100 pt-95\">\r\n        <div className=\"container\">\r\n          <div className=\"row\">\r\n            <div className=\"col-xl-6 col-lg-6\">\r\n              <div className=\"contact__info\">\r\n                <h3>Find us here.</h3>\r\n              \r\n                <p>Outstock is a premium Templates theme with advanced admin module. It’s extremely customizable, easy to use and fully responsive and retina ready. Vel illum dolore eu feugiat nulla facilisis at vero eros et accumsan et iusto odio dignissim qui blandit praesent luptatum zzril delenit augue duis dolore te feugait nulla facilisi.</p>\r\n\r\n                <div className=\"contact__social\">\r\n                  <ul>\r\n                    <li><a href=\"#\"><i className=\"fab fa-dribbble\"></i></a></li>\r\n                    <li><a href=\"#\"><i className=\"fab fa-facebook-f\"></i></a></li>\r\n                    <li><a href=\"#\"><i className=\"fab fa-twitter\"></i></a></li>\r\n                    <li><a href=\"#\"><i className=\"fab fa-behance\"></i></a></li>\r\n                    <li><a href=\"#\"><i className=\"fas fa-share-alt\"></i></a></li>\r\n                  </ul>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div className=\"col-xl-6 col-lg-6\">\r\n              <div >\r\n                <Image  src={about} width='500px' height={\"500px\"} />\r\n                <p className=\"ajax-response\"></p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default About;\r\n\r\n","C:\\Users\\TOSHIBA\\Desktop\\olizana.com.tn\\outstock\\components\\about\\index.jsx",[],[],{"ruleId":"730","severity":1,"message":"731","line":50,"column":19,"nodeType":"732","endLine":50,"endColumn":52},{"ruleId":"730","severity":1,"message":"731","line":22,"column":29,"nodeType":"732","endLine":22,"endColumn":62},{"ruleId":"730","severity":1,"message":"731","line":47,"column":17,"nodeType":"732","endLine":47,"endColumn":46},{"ruleId":"730","severity":1,"message":"731","line":64,"column":19,"nodeType":"732","endLine":64,"endColumn":76},{"ruleId":"730","severity":1,"message":"731","line":110,"column":31,"nodeType":"732","endLine":110,"endColumn":64},{"ruleId":"730","severity":1,"message":"731","line":141,"column":29,"nodeType":"732","endLine":141,"endColumn":60},{"ruleId":"730","severity":1,"message":"731","line":43,"column":33,"nodeType":"732","endLine":43,"endColumn":62},{"ruleId":"733","severity":2,"message":"734","line":136,"column":81,"nodeType":"735","messageId":"736","endLine":136,"endColumn":109,"fix":"737"},{"ruleId":"730","severity":1,"message":"731","line":11,"column":15,"nodeType":"732","endLine":11,"endColumn":46},{"ruleId":"730","severity":1,"message":"731","line":18,"column":27,"nodeType":"732","endLine":18,"endColumn":64},{"ruleId":"730","severity":1,"message":"731","line":60,"column":31,"nodeType":"732","endLine":60,"endColumn":64},{"ruleId":"730","severity":1,"message":"731","line":30,"column":19,"nodeType":"732","endLine":30,"endColumn":52},{"ruleId":"730","